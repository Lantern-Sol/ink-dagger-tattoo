{%- assign block_settings = block.settings -%}

{%- liquid
  assign show_tag = block_settings.show_tag
  assign show_button = block_settings.show_button
  assign button_label = block_settings.button_label | default: 'Read article'
  assign show_icon_link = block_settings.show_icon_link
  assign icon_link_icon = block_settings.icon_link_icon | default: 'arrow_ne'
  assign icon_link_size = block_settings.icon_link_size | default: 12
  assign icon_link_edge_padding = block_settings.icon_link_edge_padding | default: 0

  assign first_tag = ''
  if article.tags.size > 0
    assign first_tag = article.tags | first
  endif

  if block_settings.background_color != blank
    render 'contrast-override', background_color: block_settings.background_color, section_id: block.id
  endif
-%}

{% if block_settings.background_color != blank %}
  {% style %}
    blog-posts-list[section-id="{{ section.id }}"] .blog-post-item {
      --color-background: {{ block_settings.background_color }};
    }
  {% endstyle %}
{% endif %}

<div
  class="blog-post-card border-style{% if block_settings.background_color != blank %} color-custom-{{ block.id }}{% endif %}"
  style="--text-align: {{ block_settings.alignment }}; {% render 'border-override', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {% if article.image %}
    {% content_for 'block', id: 'image', type: '_blog-post-image', article: article %}
  {% endif %}

  <div class="blog-post-card__content">
    {%- if show_tag and first_tag != blank -%}
      <a
        class="blog-post-card__tag"
        href="{{ blog.url }}/tagged/{{ first_tag | handleize }}"
      >{{ first_tag }}</a>
    {%- endif -%}

    <a
      class="blog-post-card__title-link"
      href="{{ article.url }}"
      data-testid="blog-post-link"
    >
      {%- content_for 'block', id: 'heading', type: '_heading', text: article.title -%}
    </a>

    {% content_for 'block',
      id: 'blog-post-details',
      type: '_blog-post-info-text',
      alignment: block_settings.alignment,
      article: article
    %}

    <div class="blog-post-card__excerpt-row" style="padding-inline-end: {{ icon_link_edge_padding }}px; padding-block-end: {{ icon_link_edge_padding }}px;">
      {% content_for 'block',
        id: 'content',
        type: '_blog-post-description',
        article: article,
        show_read_more: false
      %}

      {%- if show_icon_link -%}
        <a
          class="blog-post-card__icon-link"
          href="{{ article.url }}"
          aria-label="{{ 'content.read_more' | t }}"
          style="{% if block_settings.icon_link_color != blank %}--icon-link-color: {{ block_settings.icon_link_color }};{% endif %}"
        >
          {%- render 'icon-or-image', icon: icon_link_icon, width: icon_link_size, class_name: 'blog-post-card__icon' -%}
        </a>
      {%- endif -%}
    </div>

    {%- if show_button -%}
      <a
        class="blog-post-card__button button button--primary"
        href="{{ article.url }}"
      >{{ button_label }}</a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .blog-post-card {
    display: flex;
    flex-direction: column;
    text-align: var(--text-align);
    column-gap: var(--columns-gap);
    height: 100%;
  }

  .blog-post-item--horizontal:has(.blog-post-card__image-container) .blog-post-card {
    & > *:first-child {
      flex-basis: 50%;
    }

    & > *:last-child {
      flex-basis: 50%;
    }
  }

  .blog-post-card__content {
    padding-block-start: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    justify-content: center;
    flex: 1 1 auto;
    min-height: 0;
  }

  .blog-post-item:not(.blog-post-item--horizontal) .blog-post-card__content {
    justify-content: flex-start;
  }

  .blog-post-item:not(.blog-post-item--horizontal) .blog-post-card__excerpt-row {
    margin-block-start: auto;
  }

  .blog-post-item--horizontal .blog-post-card__title-link .spacing-style,
  .blog-post-item--horizontal .blog-post-details,
  .blog-post-item--horizontal .blog-post-card__content-text {
    padding-inline-start: 0;
  }

  .blog-post-item .blog-post-card__image-container,
  .blog-post-item .blog-post-card__content {
    width: 100%;
  }

  /**
   * Horizontal layout (image left, content right)
   * Applied to hero posts based on total article count
   * Only applies the split layout when an image is actually present
   */
  .blog-post-item--horizontal .blog-post-card {
    flex-direction: row;
    align-items: stretch;

    @media screen and (max-width: 749px) {
      flex-direction: column;
    }
  }

  .blog-post-item--horizontal .blog-post-card__content {
    padding-inline: clamp(1rem, 3vw, 2.5rem);
    padding-block: clamp(1rem, 3vw, 2.5rem);
    
    @media screen and (max-width: 749px) {
      padding-inline: 0;
      padding-block: 1.5rem 0;
    }
  }

  .blog-post-card__content a:not(.blog-post-card__icon-link) {
    display: block;
    text-wrap: pretty;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .blog-post-card__content a:not(.blog-post-card__icon-link):hover {
    color: var(--color-foreground-subdued);
  }

  .blog-post-card__content > a:not(.blog-post-card__tag):not(.blog-post-card__button) {
    padding-block-start: 0.5rem;
  }

  @media screen and (max-width: 749px) {
    .blog-post-item--horizontal .blog-post-card__content > a:not(.blog-post-card__tag):not(.blog-post-card__button) {
      padding-block: 0.75rem 1rem;
    }
  }

  a.blog-post-card__title-link {
    color: var(--color-foreground);

    &:hover {
      color: var(--color-foreground-subdued);
    }
  }

  .blog-post-card__tag {
    display: inline-block;
    text-transform: uppercase;
    font-weight: bold;
    color: var(--color-link, currentColor);
    text-decoration: none;
    margin-block-end: 0.25rem;
  }

  .blog-post-card__button {
    align-self: var(--button-self-align, flex-start);
    margin-block-start: 0.75rem;
    width: fit-content;
    display: inline-flex;

    @media screen and (max-width: 749px) {
      margin-block-start: 1rem;
    }
  }

  .blog-post-card__excerpt-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .blog-post-card__excerpt-row .blog-post-card__content-text {
    flex: 1 1 auto;
    min-width: 0;
  }

  .blog-post-card__icon-link {
    flex-shrink: 0;
    margin-inline-start: auto;
    display: inline-flex;
    color: var(--icon-link-color, currentColor);
  }

  .blog-post-card__icon-link .blog-post-card__icon {
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "tag": null,
  "settings": [
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "Category tag"
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "Show category tag",
      "info": "Displays the article's first tag above the title.",
      "default": true
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show \"Read article\" button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read article",
      "visible_if": "{{ block.settings.show_button }}"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.border",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "solid", "label": "t:options.solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Icon link"
    },
    {
      "type": "checkbox",
      "id": "show_icon_link",
      "label": "Show icon link to article",
      "info": "Adds a small icon next to the excerpt that links to the article, like the \"Read article\" button.",
      "default": false
    },
    {
      "type": "select",
      "id": "icon_link_icon",
      "label": "t:settings.icon",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "apple", "label": "t:options.apple" },
        { "value": "arrow", "label": "t:options.arrow" },
        { "value": "banana", "label": "t:options.banana" },
        { "value": "bottle", "label": "t:options.bottle" },
        { "value": "box", "label": "t:options.box" },
        { "value": "carrot", "label": "t:options.carrot" },
        { "value": "chat_bubble", "label": "t:options.chat_bubble" },
        { "value": "check_box", "label": "t:options.check_box" },
        { "value": "clipboard", "label": "t:options.clipboard" },
        { "value": "dairy", "label": "t:options.dairy" },
        { "value": "dairy_free", "label": "t:options.dairy_free" },
        { "value": "dryer", "label": "t:options.dryer" },
        { "value": "eye", "label": "t:options.eye" },
        { "value": "fire", "label": "t:options.fire" },
        { "value": "gluten_free", "label": "t:options.gluten_free" },
        { "value": "heart", "label": "t:options.heart" },
        { "value": "iron", "label": "t:options.iron" },
        { "value": "leaf", "label": "t:options.leaf" },
        { "value": "leather", "label": "t:options.leather" },
        { "value": "lightning_bolt", "label": "t:options.lightning_bolt" },
        { "value": "lipstick", "label": "t:options.lipstick" },
        { "value": "lock", "label": "t:options.lock" },
