{% liquid
  assign slide_count = block.blocks.size
  assign icons_style = section.settings.icons_style
  assign mobile_columns_int = section.settings.mobile_columns | plus: 0

  if section.settings.figma_layout
    assign scroll_desktop = section.settings.columns
    assign scroll_mobile = 1
    assign use_infinite = true
    assign use_force_full_width = false
    assign slideshow_gutters = null
    assign gutter_style = '--gutter-slide-width: 0px;'
  else
    assign scroll_desktop = 1
    assign scroll_mobile = 1
    assign use_infinite = false
    assign use_force_full_width = true
    if section.settings.section_width == 'page-width'
      assign slideshow_gutters = 'start end'
      assign gutter_style = '--gutter-slide-width: var(--util-page-margin-offset);'
    else
      assign slideshow_gutters = null
      assign gutter_style = '--gutter-slide-width: 0px;'
    endif
  endif

  assign slideshow_class = 'carousel-content spacing-style '
  if section.settings.figma_layout
    assign slideshow_class = slideshow_class | append: 'carousel-content--figma '
  endif
  if block.settings.background_color != blank
    render 'contrast-override', background_color: block.settings.background_color, section_id: block.id
    assign slideshow_class = slideshow_class | append: ' color-custom-' | append: block.id
  endif

  assign show_arrows = false
  if icons_style != 'none'
    assign show_arrows = true
  endif

  assign slide_position = block.settings.position
  assign slideshow_extra_attrs = 'slides-to-scroll="' | append: scroll_desktop | append: '" mobile-slides-to-scroll="' | append: scroll_mobile | append: '"'
  if block.settings.height == 'fill'
    assign slide_position = 'stretch'
  endif
-%}

{% capture blocks_content %}
  {% content_for 'blocks' %}
{% endcapture %}

{% capture slideshow_style %}
  --carousel-columns: {{ section.settings.columns }};
  --carousel-mobile-columns: {{ section.settings.mobile_columns }};
  {% render 'gap-style', value: section.settings.columns_gap, name: 'carousel-gap' %}
  {% render 'spacing-style', settings: block.settings %}
  {% render 'border-override', settings: block.settings %}
{% endcapture %}

{%- liquid
  assign has_arrow_styles = false
  if section.settings.arrows_always_visible or section.settings.arrow_icon_color != blank or section.settings.arrow_background_color != blank or section.settings.arrow_border_color != blank
    assign has_arrow_styles = true
  endif
-%}

{% if has_arrow_styles %}
  {% style %}
    #shopify-section-{{ section.id }} slideshow-arrows {
      mix-blend-mode: normal;
    }
    #shopify-section-{{ section.id }} slideshow-arrows .slideshow-control {
      {% if section.settings.arrows_always_visible %}opacity: 1; animation: none !important;{% endif %}
      {% if section.settings.arrow_icon_color != blank %}color: {{ section.settings.arrow_icon_color }};{% endif %}
      {% if section.settings.arrow_background_color != blank %}background-color: {{ section.settings.arrow_background_color }};{% endif %}
      {% if section.settings.arrow_border_color != blank %}border: 2px solid {{ section.settings.arrow_border_color }};{% endif %}
    }
  {% endstyle %}
{% endif %}

{% if section.settings.figma_layout %}
  {% style %}
    #shopify-section-{{ section.id }} .carousel-content--figma slideshow-container {
      padding-inline: 68px;
    }

    #shopify-section-{{ section.id }} .carousel-content--figma slideshow-slides {
      clip-path: inset(0);
    }

    #shopify-section-{{ section.id }} .carousel-content--figma slideshow-arrows .slideshow-control {
      opacity: 1;
    }

    #shopify-section-{{ section.id }} .carousel-content--figma slideshow-slides .card {
      flex: 0 0 auto;
      width: calc(
        (100% - (var(--carousel-gap, 8px) * {{ section.settings.columns | minus: 1 }})) /
          {{ section.settings.columns }}
      );
    }

    #shopify-section-{{ section.id }} .carousel-content--figma slideshow-slides slideshow-slide {
      flex: 0 0 auto;
      scroll-snap-align: none;
      width: calc(
        (100% - (var(--carousel-gap, 8px) * {{ section.settings.columns | minus: 1 }})) /
          {{ section.settings.columns }}
      );
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .carousel-content--figma slideshow-container {
        padding-inline: 52px;
      }

      #shopify-section-{{ section.id }} .carousel-content--figma slideshow-slides .card {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .carousel-content--figma slideshow-slides slideshow-slide {
        width: 100%;
      }
    }
  {% endstyle %}
{% else %}
  {% style %}
    #shopify-section-{{ section.id }} .carousel-content slideshow-slides {
      clip-path: inset(0 var(--gutter-slide-width, 0px) 0 var(--gutter-slide-width, 0px));
    }

    #shopify-section-{{ section.id }} .carousel-content slideshow-slides .card {
      flex: 0 0 auto;
      width: calc(
        (100% - (var(--carousel-gap, 8px) * {{ section.settings.mobile_columns | minus: 1 }}) - var(--peek-next-slide-size, 0px)) /
          {{ section.settings.mobile_columns }}
      );
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .carousel-content slideshow-slides .card {
        width: calc(
          (100% - (var(--carousel-gap, 8px) * {{ section.settings.columns | minus: 1 }}) - var(--peek-next-slide-size, 0px)) /
            {{ section.settings.columns }}
        );
      }
    }
  {% endstyle %}
{% endif %}

{% if use_force_full_width %}<div class="force-full-width" style="{{ gutter_style }}">{% endif %}
  {% render 'slideshow',
    class: slideshow_class,
    style: slideshow_style,
    slides: blocks_content,
    show_arrows: show_arrows,
    icon_style: icons_style,
    icon_shape: section.settings.icons_shape,
    auto_hide_controls: false,
    infinite: use_infinite,
    slides_to_show: section.settings.columns,
    mobile_slides_to_show: mobile_columns_int,
    initial_slide: 0,
    slide_count: slide_count,
    slide_position: slide_position,
    slideshow_gutters: slideshow_gutters,
    attributes: slideshow_extra_attrs | append: ' ' | append: block.shopify_attributes
  %}
{% if use_force_full_width %}</div>{% endif %}

{% stylesheet %}
  .carousel-content slideshow-slides {
    --slideshow-gap: var(--carousel-gap);
  }

  .carousel-content slideshow-slides .card {
    flex: 0 0 auto;
    width: calc(
      (100% - (var(--carousel-gap, 8px) * (var(--carousel-mobile-columns, 2) - 1)) - var(--peek-next-slide-size, 0px)) /
        var(--carousel-mobile-columns, 2)
    );
  }

  @media screen and (min-width: 750px) {
    .carousel-content slideshow-slides .card {
      width: calc(
        (100% - (var(--carousel-gap, 8px) * (var(--carousel-columns, 4) - 1)) - var(--peek-next-slide-size, 0px)) /
          var(--carousel-columns, 4)
      );
    }
  }

  .carousel-content .slideshow-control[disabled] {
    display: none;
  }

  .carousel-content slideshow-arrows {
    padding-inline: 0;
  }

  .carousel-content .slideshow-control--next {
    margin-inline-start: auto;
  }

  .shopify-block:has(> .force-full-width) {
    grid-column: 1 / -1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.carousel_content",
  "blocks": [
    {
      "type": "_card"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:settings.card_height",
      "options": [
        {
          "value": "fit",
          "label": "t:options.fit_content"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        }
      ],
      "default": "fit"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:settings.position",
      "options": [
        {
          "value": "top",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "bottom",
          "label": "t:options.bottom"
        }
      ],
      "visible_if": "{{ block.settings.height == \"fit\" }}",
      "default": "top"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.carousel_content",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
