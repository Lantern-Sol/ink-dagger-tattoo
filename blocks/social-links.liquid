      "id": "threads_url",
      "label": "t:options.threads"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "t:options.linkedin"
    },
    {
      "type": "url",
      "id": "bluesky_url",
      "label": "t:options.bluesky"
    },
    {
      "type": "url",
      "id": "snapchat_url",
      "label": "t:options.snapchat"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "t:options.pinterest"
    },
    {
      "type": "url",
      "id": "tumblr_url",
      "label": "t:options.tumblr"
    },
    {
      "type": "url",
