{% doc %}
  Snippet: picture-modal.liquid
  Renders the zoom modal for a style gallery grid (sections/main-style-gallery.liquid).
  One instance per section, reused for every image in the grid — the calling
  section's `<style-gallery-component>` swaps the image/artist panel content
  on open/prev/next via data-modal-* hooks (see assets/style-gallery.js).
{% enddoc %}

<script src="{{ 'dialog.js' | asset_url }}" type="module"></script>
<script src="{{ 'drag-zoom-wrapper.js' | asset_url }}" type="module"></script>
<script src="{{ 'magnify-image.js' | asset_url }}" type="module"></script>

<dialog-component>
  <dialog ref="dialog" class="picture-modal dialog-modal" scroll-lock>
    <div class="picture-modal__body">
      <div class="picture-modal__viewer">
        <button
          type="button"
          class="picture-modal__close"
          on:click="dialog-component/closeDialog"
          aria-label="{{ 'accessibility.close_dialog' | t }}"
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>

        <drag-zoom-wrapper class="picture-modal__drag-zoom">
          <magnify-image class="picture-modal__magnify">
            <img data-modal-image class="picture-modal__image" ref="image" src="" alt="" loading="lazy">
          </magnify-image>
        </drag-zoom-wrapper>

        <div class="picture-modal__nav">
          <button
            type="button"
            class="picture-modal__nav-button picture-modal__nav-button--prev"
            on:click="style-gallery-component/prev"
            aria-label="{{ 'style_gallery.previous_image' | t }}"
          >
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow' -%}
            </svg>
          </button>
          <span class="picture-modal__counter" data-modal-counter></span>
          <button
            type="button"
            class="picture-modal__nav-button picture-modal__nav-button--next"
            on:click="style-gallery-component/next"
            aria-label="{{ 'style_gallery.next_image' | t }}"
          >
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow' -%}
            </svg>
          </button>
        </div>
      </div>

      <div class="picture-modal__artist">
        <div class="picture-modal__artist-photo">
          <img data-modal-artist-photo src="" alt="" loading="lazy">
        </div>
        <p class="picture-modal__artist-name" data-modal-artist-name></p>
        <div class="picture-modal__artist-tags" data-modal-artist-tags></div>
        <a
          class="picture-modal__artist-cta button-custom"
          data-modal-artist-link
          href="#"
          style="--button-background-color: #ce5454; --button-color: #1d1616; --button-border-color: #1d1616; --button-border-width: 2px; border-radius: 8px;"
        >
          {{ 'style_gallery.see_more_from_artist' | t }}
          <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20">
            {%- render 'icon', icon: 'arrow_ne' -%}
          </svg>
        </a>
      </div>
    </div>
  </dialog>
</dialog-component>

{% stylesheet %}
  .picture-modal.dialog-modal {
    padding: 0;
    border: none;
    background: rgba(29, 22, 22, 0.95);
    max-width: 100vw;
    width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
  }

  .picture-modal__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 24px;
    width: 100%;
    min-height: 100%;
    padding: 48px 24px;
    box-sizing: border-box;
    overflow-y: auto;
  }

  @media (min-width: 750px) {
    .picture-modal__body {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      padding: 64px;
    }
  }

  .picture-modal__viewer {
    position: relative;
    z-index: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
    max-width: 326px;
  }

  @media (min-width: 750px) {
    .picture-modal__viewer {
      max-width: 421px;
    }
  }

  .picture-modal__drag-zoom,
  .picture-modal__magnify {
    display: block;
    width: 100%;
  }

  .picture-modal__magnify {
    overflow: hidden;
    border-radius: 10px;
  }

  .picture-modal__image {
    display: block;
    width: 100%;
    aspect-ratio: 200 / 300;
    object-fit: cover;
    border-radius: 10px;
    transform: scale(var(--drag-zoom-scale, 1))
      translate(var(--drag-zoom-translate-x, 0), var(--drag-zoom-translate-y, 0))
      scale(var(--zoom-scale, 1));
    transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%);
    transition: transform 0.2s ease-out;
  }

  @media (min-width: 750px) {
    .picture-modal__image {
      aspect-ratio: 421 / 632;
    }
  }

  .picture-modal__close {
    position: absolute;
    z-index: 2;
    top: -16px;
    right: -16px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: #f8f5ed;
    color: #1d1616;
    border: 3px solid #1d1616;
    border-radius: 8px;
    cursor: pointer;
  }

  @media (min-width: 750px) {
    .picture-modal__close {
      top: -24px;
      right: -24px;
      width: 48px;
      height: 48px;
      padding: 12px;
    }
  }

  .picture-modal__close svg {
    width: 100%;
    height: 100%;
  }

  .picture-modal__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  .picture-modal__nav-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    color: #b0aba0;
    border: 2px solid #b0aba0;
    border-radius: 8px;
    cursor: pointer;
  }

  .picture-modal__nav-button svg {
    width: 14px;
    height: 14px;
  }

  .picture-modal__nav-button--prev svg {
    transform: rotate(180deg);
  }

  .picture-modal__counter {
    font-family: var(--font-body--family);
    font-style: italic;
    font-size: 16px;
    color: #b0aba0;
    white-space: nowrap;
  }

  @media (min-width: 750px) {
    .picture-modal__counter {
      font-size: 18px;
    }
  }

  .picture-modal__artist {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    width: 100%;
    max-width: 326px;
    padding: 16px;
    background: #f8f5ed;
    border-radius: 10px;
    box-sizing: border-box;
  }

  @media (min-width: 750px) {
    .picture-modal__artist {
      gap: 12px;
      max-width: 340px;
      padding: 24px;
    }
  }

  .picture-modal__artist-photo {
    width: 100%;
    aspect-ratio: 300 / 200;
    border-radius: 5px;
    overflow: hidden;
  }

  .picture-modal__artist-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .picture-modal__artist-name {
    margin: 8px 0 0;
    font-family: 'Libre Baskerville', var(--font-heading--family), serif;
    font-size: 24px;
    letter-spacing: -1.32px;
    color: #4c4546;
  }

  .picture-modal__artist-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .picture-modal__artist-tags:empty {
    display: none;
  }

  .picture-modal__tag {
    padding: 2px 24px;
    border: 2px solid #4c4546;
    border-radius: 99px;
    font-style: italic;
    font-size: 14px;
    color: #4c4546;
  }

  @media (min-width: 750px) {
    .picture-modal__tag {
      font-size: 18px;
    }
  }

  .picture-modal__artist-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 12px 24px;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
  }

  .picture-modal__artist-cta[hidden] {
    display: none;
  }
{% endstylesheet %}
