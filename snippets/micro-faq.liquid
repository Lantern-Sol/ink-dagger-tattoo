{%- doc -%}
  Renders the "not sure where to start" 3-step CTA band.
  Matches the micro-faq block already composed in templates/page.artists.json
  and templates/page.booking.json, rebuilt as plain Liquid so it can also be
  rendered from metaobject sections (which have no template to compose
  JSON blocks in).

  @param {string} [button_link] - defaults to shopify://pages/booking
  @param {string} [button_label] - defaults to "Get Help Choosing an Artist"

  @example
  {% render 'micro-faq' %}
{%- enddoc -%}

{%- liquid
  assign button_link = button_link | default: 'shopify://pages/booking'
  assign button_label = button_label | default: 'Get Help Choosing an Artist'
-%}

<div class="micro-faq">
  <div class="micro-faq__inner">
    <div class="micro-faq__header">
      <p class="micro-faq__eyebrow">not sure where to start</p>
      <h2 class="micro-faq__heading">We’ll guide you to the right artist</h2>
    </div>

    <div class="micro-faq__cards">
      <div class="micro-faq__card">
        <span class="micro-faq__num">01</span>
        <h3 class="micro-faq__title">Tell us your idea</h3>
        <p class="micro-faq__body">Share what you have in mind — style, placement, size, or reference images. Nothing is too vague.</p>
      </div>
      <div class="micro-faq__card">
        <span class="micro-faq__num">02</span>
        <h3 class="micro-faq__title">We match you</h3>
        <p class="micro-faq__body">Our team reviews your vision and pairs you with the artist whose portfolio best fits your concept.</p>
      </div>
      <div class="micro-faq__card">
        <span class="micro-faq__num">03</span>
        <h3 class="micro-faq__title">What type of tattoo<br>should I select?</h3>
      </div>
    </div>

    <a class="micro-faq__button button" href="{{ button_link }}">{{ button_label }}</a>
  </div>
</div>

{% style %}
  .micro-faq {
    background: #1d1616;
    color: #f8f5ed;
    border-block: 4px solid #ce5454;
    padding-block: 4rem;
  }

  .micro-faq__inner {
    box-sizing: border-box;
    max-width: 90rem;
    margin-inline: auto;
    padding-inline: 32px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 750px) {
    .micro-faq__inner {
      padding-inline: 50px;
    }
  }

  .micro-faq__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .micro-faq__eyebrow {
    margin: 0;
    font-family: var(--font-subheading--family, inherit);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ce5454;
  }

  .micro-faq__heading {
    margin: 0;
    font-family: var(--font-heading--family, serif);
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .micro-faq__cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  @media (min-width: 750px) {
    .micro-faq__cards {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .micro-faq__card {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.875rem;
    border: 1px solid rgba(248, 245, 237, 0.22);
    border-radius: 8px;
  }

  .micro-faq__num {
    font-style: italic;
    letter-spacing: 0.08em;
    color: #ce5454;
    font-size: 0.875rem;
  }

  .micro-faq__title {
    margin: 0;
    font-family: var(--font-heading--family, serif);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .micro-faq__body {
    margin: 0;
    opacity: 0.78;
    line-height: 1.5;
    font-size: 0.9375rem;
  }
{% endstyle %}
