{{ 'section-flash-filters.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .flash-filters-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    --flash-filters-ink: {{ settings.color_palette.background }};
    --flash-filters-pill-bg: {{ settings.color_palette.color1 }};
    --flash-filters-pill-bg-active: {{ settings.color_palette.background }};
    --flash-filters-pill-text-active: {{ settings.color_palette.color1 }};
    padding-block: 1rem;
    padding-inline: 0;
  }

  @media screen and (min-width: 750px) {
    .flash-filters-{{ section.id }} {
      padding-block: 0.5rem;
      padding-inline: 3rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign excluded_tags = section.settings.excluded_tags | default: '' | downcase | remove: ' '
  assign excluded_match = ',' | append: excluded_tags | append: ','
-%}

{% if collection != blank and collection.all_tags.size > 0 %}
  <div class="flash-filters flash-filters-{{ section.id }}" id="flash-filters-{{ section.id }}">
    <div class="flash-filters__inner">
      {% if section.settings.label != blank %}
        <p class="flash-filters__label">{{ section.settings.label }}</p>
      {% endif %}
      <ul class="flash-filters__list">
        {% for tag in collection.all_tags %}
          {% liquid
            assign tag_key = tag | downcase | remove: ' '
            assign tag_lookup = ',' | append: tag_key | append: ','
            if excluded_match contains tag_lookup
              continue
            endif
          %}
          <li>
            <button
              type="button"
              class="flash-filters__pill"
              data-tag="{{ tag | handleize }}"
            >
              {{- tag -}}
            </button>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <script>
    (function () {
      var sectionId = {{ section.id | json }};
      var collectionUrl = {{ collection.url | json }};
      var loadMoreLabel = {{ section.settings.load_more_label | default: 'Load more designs' | json }};
      var loadingLabel = {{ section.settings.loading_label | default: 'Loading…' | json }};
      var bar = document.getElementById('flash-filters-' + sectionId);
      if (!bar) return;

      var pills = Array.from(bar.querySelectorAll('.flash-filters__pill'));
      var activeTag = null;
      var currentPage = 1;
      var lastPage = 1;
      var loading = false;
      var wrapper = null;
      var button = null;

      function baseUrl() {
        return activeTag ? collectionUrl + '/' + activeTag : collectionUrl;
      }

      function grid() {
        return document.querySelector('.product-grid');
      }

      function themeInfiniteScroll() {
        var list = document.querySelector('results-list');
        return list && list.getAttribute('infinite-scroll') === 'true';
      }

      function maxOrder(g) {
        var max = 0;
        Array.prototype.forEach.call(g.children, function (child) {
          var value = parseInt(child.style.order, 10);
          if (value > max) max = value;
        });
        return max;
      }

      function fetchPage(page) {
        var url = baseUrl() + (page > 1 ? '?page=' + page : '');
        return fetch(url).then(function (r) {
          return r.text();
        }).then(function (html) {
          return new DOMParser().parseFromString(html, 'text/html');
        });
      }

      function syncButton() {
        var g = grid();
        if (!g || themeInfiniteScroll()) return;
        if (!wrapper) {
          wrapper = document.createElement('div');
          wrapper.className = 'flash-load-more';
          button = document.createElement('button');
          button.type = 'button';
          button.className = 'flash-load-more__button';
          button.textContent = loadMoreLabel;
          button.addEventListener('click', loadNextPage);
          wrapper.appendChild(button);
        }
        if (!wrapper.parentElement) g.parentElement.appendChild(wrapper);
        wrapper.hidden = currentPage >= lastPage;
      }

      function readState(doc) {
        var g = doc.querySelector('.product-grid');
        lastPage = g ? parseInt(g.dataset.lastPage || '1', 10) : 1;
      }

      function setBusy(state) {
        loading = state;
        if (button) {
          button.disabled = state;
          button.textContent = state ? loadingLabel : loadMoreLabel;
          if (state) {
            button.setAttribute('aria-busy', 'true');
          } else {
            button.removeAttribute('aria-busy');
          }
        }
      }

      function replaceGrid() {
        if (loading) return;
        setBusy(true);
        currentPage = 1;
        fetchPage(1).then(function (doc) {
          var g = grid();
          var fetched = doc.querySelector('.product-grid');
          if (g && fetched) {
            g.innerHTML = fetched.innerHTML;
            readState(doc);
            history.replaceState({}, '', baseUrl());
          } else {
            lastPage = 1;
          }
          syncButton();
        }).catch(function () {}).finally(function () {
          setBusy(false);
        });
      }

      function loadNextPage() {
        if (loading || currentPage >= lastPage) return;
        setBusy(true);
        fetchPage(currentPage + 1).then(function (doc) {
          var g = grid();
          var order = maxOrder(g);
          doc.querySelectorAll('.product-grid__item').forEach(function (li) {
            order += 1;
            li.style.order = order;
            g.appendChild(li);
          });
          currentPage += 1;
          syncButton();
        }).catch(function () {}).finally(function () {
          setBusy(false);
        });
      }

      pills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          if (loading) return;
          var tag = pill.dataset.tag;
          pills.forEach(function (p) {
            p.classList.remove('flash-filters__pill--active');
          });
          if (activeTag === tag) {
            activeTag = null;
          } else {
            activeTag = tag;
            pill.classList.add('flash-filters__pill--active');
          }
          replaceGrid();
        });
      });

      function init() {
        var g = grid();
        if (!g) return;
        var pathParts = location.pathname.split('/').filter(Boolean);
        var lastPart = pathParts[pathParts.length - 1];
        pills.forEach(function (p) {
          if (p.dataset.tag === lastPart) {
            activeTag = lastPart;
            p.classList.add('flash-filters__pill--active');
          }
        });
        currentPage = parseInt(new URLSearchParams(location.search).get('page') || '1', 10);
        lastPage = parseInt(g.dataset.lastPage || '1', 10);
        syncButton();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Flash Filter Pills",
  "tag": "section",
  "class": "flash-filters-wrapper",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Filter by:"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#b0aba0"
    },
    {
      "type": "text",
      "id": "excluded_tags",
      "label": "Hidden tags",
      "info": "Comma-separated list of tags that should not appear as pills (e.g. internal tags).",
      "default": "flash, inquire"
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load more button label",
      "default": "Load more designs"
    },
    {
      "type": "text",
      "id": "loading_label",
      "label": "Load more loading label",
      "default": "Loading…"
    }
  ],
  "presets": [{ "name": "Flash Filter Pills" }]
}
{% endschema %}
