{% comment %}
  Flash Library — tag filter pill bar.
  Client-side filtering, no page reload — same pattern as sections/artist-cards.liquid
  and sections/main-artist.liquid: pills toggle card visibility via a data map.
  Cards are matched by product id against the tag map rendered below.
{% endcomment %}

{{ 'section-flash-filters.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .flash-filters-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    --flash-filters-ink: {{ settings.color_palette.background }};
    --flash-filters-pill-bg: {{ settings.color_palette.color1 }};
    --flash-filters-pill-bg-active: {{ settings.color_palette.background }};
    --flash-filters-pill-text-active: {{ settings.color_palette.color1 }};
    padding-block: 1rem;
    padding-inline: 0;
  }

  @media screen and (min-width: 750px) {
    .flash-filters-{{ section.id }} {
      padding-block: 0.5rem;
      padding-inline: 3rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign excluded_tags = section.settings.excluded_tags | default: '' | downcase | remove: ' '
  assign excluded_match = ',' | append: excluded_tags | append: ','
-%}

{% if collection != blank and collection.all_tags.size > 0 %}
  <div class="flash-filters flash-filters-{{ section.id }}" id="flash-filters-{{ section.id }}">
    <div class="flash-filters__inner">
      {% if section.settings.label != blank %}
        <p class="flash-filters__label">{{ section.settings.label }}</p>
      {% endif %}
      <ul class="flash-filters__list">
        {% for tag in collection.all_tags %}
          {% liquid
            assign tag_key = tag | downcase | remove: ' '
            assign tag_lookup = ',' | append: tag_key | append: ','
            if excluded_match contains tag_lookup
              continue
            endif
          %}
          <li>
            <button
              type="button"
              class="flash-filters__pill"
              data-tag="{{ tag | handleize }}"
            >
              {{- tag -}}
            </button>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <script type="application/json" id="flash-filters-map-{{ section.id }}">
    {
      {%- paginate collection.products by 250 -%}
        {%- for product in collection.products -%}
          "{{ product.id }}": [
            {%- for tag in product.tags -%}
              {{ tag | handleize | json }}{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      {%- endpaginate -%}
    }
  </script>

  <script>
    (function () {
      var sectionId = {{ section.id | json }};
      var bar = document.getElementById('flash-filters-' + sectionId);
      var mapEl = document.getElementById('flash-filters-map-' + sectionId);
      if (!bar || !mapEl) return;

      var tagMap = {};
      try {
        tagMap = JSON.parse(mapEl.textContent);
      } catch (e) {
        return;
      }

      var pills = Array.from(bar.querySelectorAll('.flash-filters__pill'));
      var activeTag = null;

      function cards() {
        return Array.from(document.querySelectorAll('.product-grid__item[data-product-id]'));
      }

      function applyFilter() {
        cards().forEach(function (card) {
          if (!activeTag) {
            card.style.display = '';
            return;
          }
          var tags = tagMap[card.dataset.productId] || [];
          card.style.display = tags.indexOf(activeTag) !== -1 ? '' : 'none';
        });
      }

      pills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          var tag = pill.dataset.tag;
          pills.forEach(function (p) {
            p.classList.remove('flash-filters__pill--active');
          });
          if (activeTag === tag) {
            activeTag = null;
          } else {
            activeTag = tag;
            pill.classList.add('flash-filters__pill--active');
          }
          applyFilter();
        });
      });

      {% comment %} Re-apply when infinite scroll appends more cards {% endcomment %}
      var grid = document.querySelector('.product-grid');
      if (grid && 'MutationObserver' in window) {
        new MutationObserver(function () {
          if (activeTag) applyFilter();
        }).observe(grid, { childList: true, subtree: true });
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Flash Filter Pills",
  "tag": "section",
  "class": "flash-filters-wrapper",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Filter by:"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#b0aba0"
    },
    {
      "type": "text",
      "id": "excluded_tags",
      "label": "Hidden tags",
      "info": "Comma-separated list of tags that should not appear as pills (e.g. internal tags).",
      "default": "flash"
    }
  ],
  "presets": [{ "name": "Flash Filter Pills" }]
}
{% endschema %}
