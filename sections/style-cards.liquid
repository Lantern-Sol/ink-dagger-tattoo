{%- liquid
  assign has_color_override = false
  if section.settings.background_color != blank or section.settings.text_color != blank
    assign has_color_override = true
  endif
  assign styles = shop.metaobjects.style.values
  assign style_categories = shop.metaobjects.style_category.values
  assign top_pad = section.settings['padding-block-start'] | default: 64
  assign bot_pad = section.settings['padding-block-end'] | default: 64
-%}

{%- if has_color_override -%}
  {%- render 'contrast-override',
    background_color: section.settings.background_color,
    text_color: section.settings.text_color,
    section_id: section.id -%}
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --style-cards-accent: {{ section.settings.accent_color | default: '#ce5454' }};
    --style-cards-card-border-color: {{ section.settings.card_border_color | default: '#f8f5ed' }};
    --style-cards-card-border-opacity: {{ section.settings.card_border_opacity | default: 20 }}%;
  }
{%- endstyle -%}

<div
  class="style-cards{% if has_color_override %} color-custom-{{ section.id }}{% endif %}"
  style="padding-bottom: {{ bot_pad }}px;{% if style_categories == blank %} padding-top: {{ top_pad }}px;{% endif %}"
>

  {%- if style_categories != blank -%}
    <div class="style-cards__filter-bar" id="style-filter-bar-{{ section.id }}" style="margin-bottom: {{ top_pad }}px;">
      <div class="style-cards__filter-inner">
        {%- if section.settings.filter_label != blank -%}
          <span class="style-cards__filter-label">{{ section.settings.filter_label | escape }}</span>
        {%- endif -%}
        <div class="style-cards__filter-categories" id="style-filter-categories-{{ section.id }}">
          {%- for cat in style_categories -%}
            {%- assign subcategory_list = '' -%}
            {%- for style_entry in cat.styles.value -%}
              {%- unless forloop.first -%}{%- assign subcategory_list = subcategory_list | append: ',' -%}{%- endunless -%}
              {%- assign subcategory_list = subcategory_list | append: style_entry.name.value -%}
            {%- endfor -%}
            <button
              type="button"
              class="style-cards__filter-cat"
              data-category="{{ cat.name.value | escape }}"
              data-subcategories="{{ subcategory_list | escape }}"
            >{{ cat.name.value | escape }}</button>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- paginate shop.metaobjects.project.values by 250 -%}
    <div class="style-cards__grid" id="style-cards-grid-{{ section.id }}">
      {%- for style in styles -%}
        {%- liquid
          assign card_image = blank
          for project_entry in shop.metaobjects.project.values
            if project_entry.style.value.system.id == style.system.id
              assign card_image = project_entry.images.value | first
              break
            endif
          endfor
        -%}
        {%- if card_image == blank -%}
          {%- continue -%}
        {%- endif -%}
        <a class="style-card" href="{{ style.system.url }}" data-style-name="{{ style.name.value | escape }}">
          <div class="style-card__image">
            {{ card_image | image_url: width: 700 | image_tag:
              loading: 'lazy',
              widths: '345, 500, 700',
              sizes: '(min-width: 750px) calc(33vw - 40px), calc(100vw - 64px)',
              alt: style.name.value | escape }}
          </div>
          <div class="style-card__info">
            <h3 class="style-card__name">{{ style.name.value | escape }}</h3>
            <svg class="style-card__arrow" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow_ne' -%}
            </svg>
          </div>
        </a>
      {%- else -%}
        <p class="style-cards__empty">No styles found.</p>
      {%- endfor -%}
    </div>
  {%- endpaginate -%}

</div>

{%- if style_categories != blank -%}
<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var grid = document.getElementById('style-cards-grid-' + sectionId);
    var filterBar = document.getElementById('style-filter-bar-' + sectionId);

    if (!grid || !filterBar) return;

    var cards = Array.from(grid.querySelectorAll('.style-card'));
    var catBtns = Array.from(filterBar.querySelectorAll('.style-cards__filter-cat'));

    if (!catBtns.length) return;

    var presentStyles = new Set();
    cards.forEach(function (card) {
      var name = card.dataset.styleName;
      if (name) presentStyles.add(name);
    });

    catBtns.forEach(function (btn) {
      var subcats = parseSubcats(btn);
      if (!subcats.some(function (s) { return presentStyles.has(s); })) {
        btn.style.display = 'none';
      }
    });

    var activeCategory = null;

    function parseSubcats(btn) {
      return (btn.dataset.subcategories || '').split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    }

    function showAll() {
      cards.forEach(function (c) { c.style.display = ''; });
    }

    function filterByCategory(subcatArray) {
      var set = new Set(subcatArray);
      cards.forEach(function (c) {
        c.style.display = set.has(c.dataset.styleName) ? '' : 'none';
      });
    }

    catBtns.forEach(function (catBtn) {
      catBtn.addEventListener('click', function () {
        var cat = catBtn.dataset.category;
        var subcats = parseSubcats(catBtn);

        if (activeCategory === cat) {
          activeCategory = null;
          catBtns.forEach(function (b) { b.classList.remove('style-cards__filter-cat--active'); });
          showAll();
        } else {
          activeCategory = cat;
          catBtns.forEach(function (b) { b.classList.remove('style-cards__filter-cat--active'); });
          catBtn.classList.add('style-cards__filter-cat--active');
          filterByCategory(subcats);
        }
      });
    });
  })();
</script>
{%- endif -%}

{% stylesheet %}
  .style-cards {
    position: relative;
  }

  .style-cards__filter-bar {
    width: 100%;
    background: #b0aba0;
    border-top: 1px solid rgba(29, 22, 22, 0.12);
    border-bottom: 1px solid rgba(29, 22, 22, 0.12);
  }

  .style-cards__filter-inner {
    box-sizing: border-box;
    max-width: var(--page-content-width, 1280px);
    margin-inline: auto;
    padding-inline: 24px;
    padding-block: 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  @media (min-width: 750px) {
    .style-cards__filter-inner {
      padding-inline: 50px;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 24px;
    }
  }

  .style-cards__filter-label {
    font-family: var(--font-h1--family);
    font-style: italic;
    font-size: 18px;
    color: #1d1616;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .style-cards__filter-categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    width: 100%;
  }

  @media (min-width: 750px) {
    .style-cards__filter-categories {
      gap: 16px;
      width: auto;
    }
  }

  .style-cards__filter-cat {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: #f8f5ed;
    border: 2px solid #1d1616;
    border-radius: 8px;
    font-family: var(--font-h1--family);
    font-size: 14px;
    font-weight: 400;
    font-style: italic;
    color: #1d1616;
    cursor: pointer;
    opacity: 0.8;
    transition: background 0.2s, color 0.2s, border-color 0.2s, opacity 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 750px) {
    .style-cards__filter-cat {
      font-size: 18px;
      padding: 11px 20px;
    }
  }

  .style-cards__filter-cat--active,
  .style-cards__filter-cat:hover {
    background: #1d1616;
    color: #f8f5ed;
    opacity: 1;
  }

  .style-cards__grid {
    box-sizing: border-box;
    max-width: var(--page-content-width, 1280px);
    margin-inline: auto;
    padding-inline: 32px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 750px) {
    .style-cards__grid {
      padding-inline: 50px;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px 32px;
    }
  }

  .style-cards__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-foreground-subdued);
  }

  .style-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-bottom: 25px;
    background: #1d1616;
    border: 1px solid color-mix(in srgb, var(--style-cards-card-border-color) var(--style-cards-card-border-opacity), transparent);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: #f8f5ed;
    transition: box-shadow var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .style-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .style-card__image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    flex-shrink: 0;
  }

  .style-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .style-card:hover .style-card__image img {
    transform: scale(var(--hover-subtle-zoom-amount, 1.015));
  }

  .style-card__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 15px;
  }

  .style-card__name {
    margin: 0;
    font-family: var(--font-h1--family, serif);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.18;
    color: inherit;
  }

  .style-card__arrow {
    flex-shrink: 0;
    color: var(--style-cards-accent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Style Cards",
  "tag": "section",
  "class": "style-cards-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Link & accent color",
      "default": "#ce5454"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#f8f5ed"
    },
    {
      "type": "range",
      "id": "card_border_opacity",
      "label": "Card border opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style filter bar"
    },
    {
      "type": "text",
      "id": "filter_label",
      "label": "Filter label",
      "default": "Category"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Style Cards",
      "settings": {
        "accent_color": "#ce5454"
      }
    }
  ]
}
{% endschema %}
