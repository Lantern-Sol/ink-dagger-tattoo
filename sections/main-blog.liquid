<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  assign layout_type = section.settings.layout_type | default: 'smart-mix'
  assign columns = section.settings.columns | default: 3
  assign posts_per_page = section.settings.posts_per_page | default: 7
  assign show_category_tabs = section.settings.show_category_tabs
  assign tabs_alignment = section.settings.tabs_alignment | default: 'center'
  assign show_pagination = section.settings.show_pagination
  assign pagination_type = section.settings.pagination_type | default: 'numbered'
  assign load_more_label = section.settings.load_more_label | default: 'Load more stories'
  assign load_more_style = section.settings.load_more_style | default: 'button'
  assign featured_bg_image = section.settings.featured_card_background_image
  assign featured_bg_position = section.settings.featured_card_background_position | default: 'cover'
  assign featured_bg_overlay_opacity = section.settings.featured_card_background_overlay_opacity | default: 0

  assign featured_inline_style = ''
  if featured_bg_image != blank
    assign featured_bg_url = featured_bg_image | image_url: width: 2400
    assign featured_bg_overlay_alpha = featured_bg_overlay_opacity | divided_by: 100.0
    assign featured_inline_style = '--featured-bg-image:url(' | append: featured_bg_url | append: ');--featured-bg-size:' | append: featured_bg_position | append: ';--featured-bg-overlay:rgb(0 0 0 / ' | append: featured_bg_overlay_alpha | append: ');'
  endif

  assign all_label = section.settings.all_tab_label | default: 'All'
  assign filter_label = section.settings.filter_label

  assign current_tag = ''
  if current_tags != blank
    assign current_tag = current_tags | first
  endif

  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif

  # Filter label typography — mirrors the "type_preset" system on blocks/text.liquid,
  # hand-rolled here (rather than via snippets/typography-style.liquid) because that
  # snippet expects one flat, unprefixed settings object and this section needs two
  # independent typography groups (label + tabs) on a single section.settings object.
  assign filter_label_type_preset = section.settings.filter_label_type_preset | default: 'h6'
  assign filter_label_class = filter_label_type_preset
  assign filter_label_style = ''
  if filter_label_type_preset == 'custom'
    assign filter_label_class = 'custom-typography'
    assign filter_label_style = filter_label_style | append: '--font-family:' | append: section.settings.filter_label_font | append: ';'
    if section.settings.filter_label_enable_custom_font_weight and section.settings.filter_label_weight != blank
      assign filter_label_style = filter_label_style | append: '--font-weight:' | append: section.settings.filter_label_weight | append: ';'
    endif
    if section.settings.filter_label_font_size != blank
      assign filter_label_class = filter_label_class | append: ' custom-font-size'
      assign filter_label_style = filter_label_style | append: '--font-size:' | append: section.settings.filter_label_font_size | append: ';'
    endif
    if section.settings.filter_label_line_height == 'custom'
      assign filter_label_style = filter_label_style | append: '--line-height:' | append: section.settings.filter_label_custom_line_height | append: ';'
    else
      assign filter_label_style = filter_label_style | append: '--line-height:var(--line-height--body-' | append: section.settings.filter_label_line_height | append: ');'
    endif
    assign filter_label_style = filter_label_style | append: '--letter-spacing:var(--letter-spacing--body-' | append: section.settings.filter_label_letter_spacing | append: ');'
    assign filter_label_style = filter_label_style | append: '--text-transform:' | append: section.settings.filter_label_case | append: ';'
  endif

  # Tab pill typography — same pattern as the filter label above.
  assign tab_type_preset = section.settings.tab_type_preset | default: 'custom'
  assign tab_type_class = tab_type_preset
  assign tab_type_style = ''
  if tab_type_preset == 'custom'
    assign tab_type_class = 'custom-typography'
    assign tab_type_style = tab_type_style | append: '--font-family:' | append: section.settings.tab_font | append: ';'
    if section.settings.tab_enable_custom_font_weight and section.settings.tab_weight != blank
      assign tab_type_style = tab_type_style | append: '--font-weight:' | append: section.settings.tab_weight | append: ';'
    endif
    if section.settings.tab_font_size != blank
      assign tab_type_class = tab_type_class | append: ' custom-font-size'
      assign tab_type_style = tab_type_style | append: '--font-size:' | append: section.settings.tab_font_size | append: ';'
    endif
    if section.settings.tab_line_height == 'custom'
      assign tab_type_style = tab_type_style | append: '--line-height:' | append: section.settings.tab_custom_line_height | append: ';'
    else
      assign tab_type_style = tab_type_style | append: '--line-height:var(--line-height--body-' | append: section.settings.tab_line_height | append: ');'
    endif
    assign tab_type_style = tab_type_style | append: '--letter-spacing:var(--letter-spacing--body-' | append: section.settings.tab_letter_spacing | append: ');'
    assign tab_type_style = tab_type_style | append: '--text-transform:' | append: section.settings.tab_case | append: ';'
  endif

  # Tabs band + pill appearance
  assign tabs_band_style = ''
  if section.settings.tabs_background_color != blank
    assign tabs_band_style = tabs_band_style | append: '--tabs-band-bg:' | append: section.settings.tabs_background_color | append: ';'
  endif
  if section.settings.tabs_divider_color != blank
    assign tabs_band_style = tabs_band_style | append: '--tabs-band-divider:' | append: section.settings.tabs_divider_color | append: ';'
  endif
  assign tabs_band_style = tabs_band_style | append: '--tabs-band-spacing:' | append: section.settings.tabs_bottom_spacing | append: 'px;--tabs-band-spacing-mobile:' | append: section.settings.tabs_bottom_spacing_mobile | append: 'px;'
  assign tab_pill_style = '--tab-bg:' | append: section.settings.tab_background_color | append: ';--tab-active-bg:' | append: section.settings.tab_active_background_color | append: ';--tab-text:' | append: section.settings.tab_text_color | append: ';--tab-border-color:' | append: section.settings.tab_border_color | append: ';--tab-border-width:' | append: section.settings.tab_border_width | append: 'px;--tab-radius:' | append: section.settings.tab_corner_radius | append: 'px;'
%}

<blog-posts-list section-id="{{ section.id }}">
  <div
    class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  ></div>
  <div
    class="
      section
      {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
      blog-posts
      blog-posts--{{ layout_type }}
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="
      {% render 'spacing-style', settings: section.settings %}
      --blog-posts-columns: {{ columns }};
    "
  >
    {% content_for 'blocks' %}

    {%- if show_category_tabs -%}
      <div class="blog-category-tabs-band" style="{{ tabs_band_style }}">
        <nav
          class="blog-category-tabs blog-category-tabs--{{ tabs_alignment }}"
          aria-label="Article categories"
        >
          {%- if filter_label != blank -%}
            <div class="blog-category-tabs__label {{ filter_label_class }}" style="{{ filter_label_style }}">{{ filter_label }}</div>
          {%- endif -%}
          <ul class="blog-category-tabs__list" role="list" style="{{ tab_pill_style }}">
            <li class="blog-category-tabs__item">
              <a
                href="{{ blog.url }}"
                class="blog-category-tabs__link {{ tab_type_class }}{% if current_tag == blank %} is-active{% endif %}"
                style="{{ tab_type_style }}"
                {% if current_tag == blank %}aria-current="page"{% endif %}
              >{{ all_label }}</a>
            </li>
            {%- for tag in blog.all_tags -%}
              <li class="blog-category-tabs__item">
                <a
                  href="{{ blog.url }}/tagged/{{ tag | handleize }}"
                  class="blog-category-tabs__link {{ tab_type_class }}{% if tag == current_tag %} is-active{% endif %}"
                  style="{{ tab_type_style }}"
                  {% if tag == current_tag %}aria-current="page"{% endif %}
                >{{ tag }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>
    {%- endif -%}

    {%- if show_pagination -%}
      {% paginate blog.articles by posts_per_page %}
        {%- assign paginated_articles = blog.articles -%}
        <div ref="grid" class="blog-posts-container" data-last-page="{{ paginate.pages }}">
          {% for article in paginated_articles %}
            {% liquid
              assign col_span = 2
              assign scale = 0.6
              assign is_horizontal = false
              assign is_featured = false
              assign items_on_page = paginated_articles.size

              if layout_type == 'featured-grid'
                if forloop.first
                  assign col_span = columns
                  assign scale = 1
                  assign is_horizontal = true
                  assign is_featured = true
                else
                  assign col_span = 1
                  assign scale = 0.8
                endif
              elsif layout_type == 'grid'
                assign col_span = 1
                assign scale = 0.8
              else
                case items_on_page
                  when 1
                    assign col_span = 6
                    assign scale = 1
                    assign is_horizontal = true
                  when 2
                    assign col_span = 3
                    assign scale = 0.8
                  when 3
                    if forloop.index == 1
                      assign col_span = 6
                      assign scale = 1
                      assign is_horizontal = true
                    else
                      assign col_span = 3
                      assign scale = 0.8
                    endif
                  when 4
                    assign col_span = 3
                    assign scale = 0.8
                  when 5
                    if forloop.index == 1
                      assign col_span = 6
                      assign scale = 1
                      assign is_horizontal = true
                    else
                      assign col_span = 3
                      assign scale = 0.8
                    endif
                  else
                    if forloop.index == 1
                      assign col_span = 6
                      assign scale = 1
                      assign is_horizontal = true
                    elsif forloop.index <= 3
                      assign col_span = 3
                      assign scale = 0.8
                    else
                      assign col_span = 2
                      assign scale = 0.6
                    endif
                endcase
              endif
            %}
            {% style %}
              [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
                --col-span: {{ col_span }};
                --blog-post-card-scale: {{ scale }};
              }

              @media screen and (max-width: 749px) {
                [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
                  --col-span: {% if layout_type == 'featured-grid' or layout_type == 'grid' %}1{% else %}6{% endif %};
                  --blog-post-card-scale: 0.5;
                }
              }
            {% endstyle %}
            <div
              class="
                blog-post-item
                {% if is_horizontal %}blog-post-item--horizontal{% endif %}
                {% if is_featured %}blog-post-item--featured{% endif %}
              "
              data-testid="blog-post-item"
              data-blog-index="{{ section.id }}-{{ forloop.index }}"
              ref="cards[]"
              data-page="{{ paginate.current_page }}"
              {% if is_featured and featured_inline_style != blank %}style="{{ featured_inline_style }}"{% endif %}
            >
              {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
            </div>
          {% endfor %}
        </div>
        {%- if pagination_type == 'load_more' -%}
          {%- if paginate.next -%}
            <div class="blog-posts-load-more">
              <a
                href="{{ paginate.next.url }}"
                class="{{ load_more_style }} blog-posts-load-more__button"
                data-load-more-button
                data-next-url="{{ paginate.next.url }}"
              >{{ load_more_label }}</a>
            </div>
          {%- endif -%}
        {%- else -%}
          {%- render 'pagination-controls', paginate: paginate -%}
        {%- endif -%}
      {% endpaginate %}
    {%- else -%}
      <div ref="grid" class="blog-posts-container">
        {% for article in blog.articles %}
          {% liquid
            assign col_span = 2
            assign scale = 0.6
            assign is_horizontal = false
            assign is_featured = false
            assign items_on_page = blog.articles.size

            if layout_type == 'featured-grid'
              if forloop.first
                assign col_span = columns
                assign scale = 1
                assign is_horizontal = true
                assign is_featured = true
              else
                assign col_span = 1
                assign scale = 0.8
              endif
            elsif layout_type == 'grid'
              assign col_span = 1
              assign scale = 0.8
            else
              case items_on_page
                when 1
                  assign col_span = 6
                  assign scale = 1
                  assign is_horizontal = true
                when 2
                  assign col_span = 3
                  assign scale = 0.8
                when 3
                  if forloop.index == 1
                    assign col_span = 6
                    assign scale = 1
                    assign is_horizontal = true
                  else
                    assign col_span = 3
                    assign scale = 0.8
                  endif
                when 4
                  assign col_span = 3
                  assign scale = 0.8
                when 5
                  if forloop.index == 1
                    assign col_span = 6
                    assign scale = 1
                    assign is_horizontal = true
                  else
                    assign col_span = 3
                    assign scale = 0.8
                  endif
                else
                  if forloop.index == 1
                    assign col_span = 6
                    assign scale = 1
                    assign is_horizontal = true
                  elsif forloop.index <= 3
                    assign col_span = 3
                    assign scale = 0.8
                  else
                    assign col_span = 2
                    assign scale = 0.6
                  endif
              endcase
            endif
          %}
          {% style %}
            [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
              --col-span: {{ col_span }};
              --blog-post-card-scale: {{ scale }};
            }

            @media screen and (max-width: 749px) {
              [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
                --col-span: {% if layout_type == 'featured-grid' or layout_type == 'grid' %}1{% elsif is_horizontal %}6{% else %}3{% endif %};
                --blog-post-card-scale: 0.5;
              }
            }
          {% endstyle %}
          <div
            class="
              blog-post-item
              {% if is_horizontal %}blog-post-item--horizontal{% endif %}
              {% if is_featured %}blog-post-item--featured{% endif %}
            "
            data-testid="blog-post-item"
            data-blog-index="{{ section.id }}-{{ forloop.index }}"
            {% if is_featured and featured_inline_style != blank %}style="{{ featured_inline_style }}"{% endif %}
          >
            {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
          </div>
        {% endfor %}
      </div>
    {%- endif -%}
  </div>
</blog-posts-list>

{% stylesheet %}
  /**
   * Blog posts page layout
   */
  .blog-posts {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
    --columns-gap: 1rem;
    --rows-gap: 1.5rem;
  }

  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    width: 100%;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  /**
   * Blog post item grid positioning and scaling.
   * Layout is calculated in Liquid based on total article count.
   * Mobile overrides are applied per-item in inline styles for proper specificity.
   */
  .blog-post-item {
    grid-column: span var(--col-span);
    background-color: var(--color-background);
  }

  /**
   * When there's no image, the blog post item has a border.
   */
  .blog-post-item {
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-20));
    padding: 0 1rem 1rem;
  }

  .blog-post-item:has(.blog-post-card__image-container) {
    border: none;
    padding: 0;
  }

  /**
   * Featured-grid layout: first article spans full width as a horizontal hero,
   * remaining articles fill a uniform N-column grid below.
   */
  .blog-posts--featured-grid .blog-posts-container {
    grid-template-columns: repeat(var(--blog-posts-columns, 3), 1fr);
  }

  .blog-posts--featured-grid .blog-post-item--featured {
    grid-column: 1 / -1;
  }

  .blog-posts--featured-grid .blog-post-item--featured {
    position: relative;
    isolation: isolate;
    margin-bottom: 1rem;
  }

  /**
   * Full-viewport background break-out.
   * The pseudo-element extends edge-to-edge across the viewport while the
   * card content stays inside the section's narrow page width.
   */
  .blog-posts--featured-grid .blog-post-item--featured::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    z-index: -2;
    background-image: var(--featured-bg-image, none);
    background-size: var(--featured-bg-size, cover);
    background-position: center;
    background-repeat: no-repeat;
    pointer-events: none;
  }

  .blog-posts--featured-grid .blog-post-item--featured::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    z-index: -1;
    background: var(--featured-bg-overlay, transparent);
    pointer-events: none;
  }

  .blog-posts--featured-grid .blog-post-item--featured .blog-post-card {
    background: transparent;
    color: rgb(var(--featured-card-fg-rgb, var(--color-foreground-rgb)));
    padding: var(--gap-2xl, 32px);
    border-radius: 0;

    @media screen and (max-width: 749px) {
      padding: 2.5rem 0;
    }
  }

  /**
   * Featured article heading uses the h5 type preset; the grid cards stay
   * at the static block's h6 setting from the template. Scope to the
   * heading text-block (.h6) so the excerpt/rte block isn't affected.
   */
  .blog-posts--featured-grid .blog-post-item--featured .blog-post-card__content .text-block.h6,
  .blog-posts--featured-grid .blog-post-item--featured .blog-post-card__content .text-block.h6 :is(h1, h2, h3, h4, h5, h6) {
    font-family: var(--font-h5--family);
    font-size: var(--font-h5--size);
    line-height: var(--font-h5--line-height);
  }

  /**
   * Allow the featured background pseudo to extend to the viewport edges.
   * Ancestors must NOT have overflow:hidden/clip or the ::before will be
   * cropped to the narrow content width.
   */
  .blog-posts--featured-grid,
  .blog-posts--featured-grid .blog-posts-container,
  .blog-posts--featured-grid .blog-post-item--featured {
    overflow: visible;
  }

  @media screen and (max-width: 749px) {
    .blog-posts--featured-grid .blog-posts-container {
      grid-template-columns: repeat(2, 1fr);
    }

    .blog-post-item:not(.blog-post-item--horizontal):not(.blog-post-item--featured) .blog-post-card__image {
      aspect-ratio: 1 / 1;
      height: auto;
    }
  }

  /**
   * Grid layout: every article renders as a uniform grid cell, no featured/hero post.
   */
  .blog-posts--grid .blog-posts-container {
    grid-template-columns: repeat(var(--blog-posts-columns, 4), 1fr);
  }

  @media screen and (max-width: 749px) {
    .blog-posts--grid .blog-posts-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /**
   * "Load more" pagination button
   */
  .blog-posts-load-more {
    display: flex;
    justify-content: center;
    margin-block-start: var(--gap-xl, 32px);
  }

  @media screen and (max-width: 749px) {
    .blog-posts-load-more__button {
      width: 100%;
    }
  }

  /**
   * Category tabs band
   */
  .blog-category-tabs-band {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-block-end: var(--tabs-band-spacing, 40px);
    background-color: var(--tabs-band-bg, transparent);
    border-block: 1px solid var(--tabs-band-divider, transparent);
  }

  .blog-category-tabs {
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: var(--page-width, 1440px);
    margin-inline: auto;
    padding: 8px 151px;
  }

  .blog-category-tabs--center {
    justify-content: center;
  }

  .blog-category-tabs--right {
    justify-content: flex-end;
  }

  .blog-category-tabs__label {
    flex: 0 0 auto;
    margin: 0;
    white-space: nowrap;
  }

  .blog-category-tabs__label p {
    margin: 0;
  }

  .blog-category-tabs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 16px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .blog-category-tabs__list::-webkit-scrollbar {
    display: none;
  }

  .blog-category-tabs__item {
    flex: 0 0 auto;
  }

  .blog-category-tabs__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 20px;
    color: var(--tab-text);
    background-color: var(--tab-bg);
    border: var(--tab-border-width, 2px) solid var(--tab-border-color);
    border-radius: var(--tab-radius, 8px);
    text-decoration: none;
    transition: background-color 120ms ease, border-color 120ms ease;
    white-space: nowrap;
  }

  .blog-category-tabs__link.is-active {
    background-color: var(--tab-active-bg, var(--tab-bg));
  }

  @media screen and (max-width: 749px) {
    .blog-category-tabs-band {
      margin-block-end: var(--tabs-band-spacing-mobile, 24px);
    }

    .blog-category-tabs {
      flex-direction: column;
      align-items: stretch;
      padding: 16px 32px;
    }

    .blog-category-tabs__list {
      width: auto;
      gap: 8px;
      margin-inline-end: -32px;
    }

    .blog-category-tabs__link {
      padding: 8px 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "smart-mix", "label": "Smart mix (hero + standard + compact)" },
        { "value": "featured-grid", "label": "Featured + uniform grid" },
        { "value": "grid", "label": "Grid (no featured post)" }
      ],
      "default": "featured-grid"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Grid columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "visible_if": "{{ section.settings.layout_type == 'featured-grid' or section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "image_picker",
      "id": "featured_card_background_image",
      "label": "Featured card background image",
      "info": "Sits behind the first article. Use a darker image or pair with the overlay below for legibility.",
      "visible_if": "{{ section.settings.layout_type == 'featured-grid' }}"
    },
    {
      "type": "select",
      "id": "featured_card_background_position",
      "label": "Background fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "auto", "label": "Original size" }
      ],
      "default": "cover",
