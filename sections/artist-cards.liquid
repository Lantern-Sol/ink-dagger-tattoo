{%- liquid
  assign has_color_override = false
  if section.settings.background_color != blank or section.settings.text_color != blank
    assign has_color_override = true
  endif
  assign artists = shop.metaobjects.artist.values
  assign style_categories = shop.metaobjects.style_category.values
  assign show_filter = section.settings.show_filter_bar
  assign has_heading_blocks = false
  if section.blocks.size > 0
    assign has_heading_blocks = true
  endif
  assign top_pad = section.settings['padding-block-start'] | default: 64
  assign bot_pad = section.settings['padding-block-end'] | default: 64
  assign apply_top_to_section = true
  assign apply_top_to_grid = false
  if show_filter and has_heading_blocks == false
    assign apply_top_to_section = false
    assign apply_top_to_grid = true
  endif
-%}

{%- if has_color_override -%}
  {%- render 'contrast-override',
    background_color: section.settings.background_color,
    text_color: section.settings.text_color,
    section_id: section.id -%}
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --artist-cards-accent: {{ section.settings.accent_color | default: '#ce5454' }};
    {%- if section.settings.card_border_color != blank -%}
      --artist-cards-card-border: {{ section.settings.card_border_color }};
    {%- endif -%}
  }
{%- endstyle -%}

<div
  class="artist-cards{% if has_color_override %} color-custom-{{ section.id }}{% endif %}{% if section.settings.show_border %} artist-cards--bordered{% endif %}"
  style="padding-bottom: {{ bot_pad }}px;{% if apply_top_to_section %} padding-top: {{ top_pad }}px;{% endif %}"
>

  {%- if has_heading_blocks -%}
    <div class="artist-cards__header">
      {% content_for 'blocks' %}
    </div>
  {%- endif -%}

  {%- if show_filter and style_categories != blank -%}
    <div class="artist-cards__filter-bar" id="artist-filter-bar-{{ section.id }}">
      <div class="artist-cards__filter-inner">
        {%- if section.settings.filter_label != blank -%}
          <span class="artist-cards__filter-label">{{ section.settings.filter_label | escape }}</span>
        {%- endif -%}
        <div class="artist-cards__filter-categories" id="artist-filter-categories-{{ section.id }}">
          {%- for cat in style_categories -%}
            {%- assign subcategory_list = '' -%}
            {%- for style_entry in cat.styles.value -%}
              {%- unless forloop.first -%}{%- assign subcategory_list = subcategory_list | append: ',' -%}{%- endunless -%}
              {%- assign subcategory_list = subcategory_list | append: style_entry.name.value -%}
            {%- endfor -%}
            <button
              type="button"
              class="artist-cards__filter-cat"
              data-category="{{ cat.name.value | escape }}"
              data-subcategories="{{ subcategory_list | escape }}"
            >{{ cat.name.value | escape }}</button>
          {%- endfor -%}
        </div>
      </div>
      <div class="artist-cards__filter-subcategory-row" id="artist-filter-subcategory-row-{{ section.id }}" style="display: none;">
        <div class="artist-cards__filter-inner artist-cards__filter-inner--sub">
          <div class="artist-cards__filter-pills" id="artist-filter-pills-{{ section.id }}"></div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div
    class="artist-cards__grid-wrap"
    style="{% if apply_top_to_grid %}padding-top: {{ top_pad }}px;{% elsif show_filter %}padding-top: 32px;{% endif %}"
  >
    <div class="artist-cards__grid" id="artist-cards-grid-{{ section.id }}">
      {%- for artist_entry in artists -%}
        {%- assign profile = artist_entry.profile_image.value -%}
        <a
          class="artist-card"
          href="{{ artist_entry.system.url }}"
          data-specialties="{{ artist_entry.specialty.value | escape }}"
        >
          <div class="artist-card__image">
            {%- if profile != blank -%}
              {{ profile | image_url: width: 600 | image_tag:
                loading: 'lazy',
                widths: '160, 275, 400, 600',
                sizes: '(min-width: 750px) calc(25vw - 40px), calc(50vw - 24px)',
                alt: artist_entry.name.value | escape }}
            {%- endif -%}
          </div>
          <div class="artist-card__info">
            <h3 class="artist-card__name">{{ artist_entry.name.value | escape }}</h3>
            {%- if artist_entry.specialty.value != blank -%}
              <p class="artist-card__specialty">{{ artist_entry.specialty.value | escape }}</p>
            {%- endif -%}
            <span class="artist-card__link">Quick view &rarr;</span>
          </div>
        </a>
      {%- else -%}
        <p class="artist-cards__empty">No artists found.</p>
      {%- endfor -%}
    </div>
  </div>

</div>

{%- if show_filter and style_categories != blank -%}
<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var grid = document.getElementById('artist-cards-grid-' + sectionId);
    var filterBar = document.getElementById('artist-filter-bar-' + sectionId);
    var subcatRow = document.getElementById('artist-filter-subcategory-row-' + sectionId);
    var pillsContainer = document.getElementById('artist-filter-pills-' + sectionId);

    if (!grid || !filterBar || !subcatRow || !pillsContainer) return;

    var cards = Array.from(grid.querySelectorAll('.artist-card'));
    var catBtns = Array.from(filterBar.querySelectorAll('.artist-cards__filter-cat'));

    if (!catBtns.length) return;

    var presentSpecs = new Set();
    cards.forEach(function (card) {
      var raw = card.dataset.specialties || '';
      raw.split(',').map(function (s) { return s.trim(); }).filter(Boolean).forEach(function (s) {
        presentSpecs.add(s);
      });
    });

    catBtns.forEach(function (btn) {
      var subcats = parseSubcats(btn);
      if (!subcats.some(function (s) { return presentSpecs.has(s); })) {
        btn.style.display = 'none';
      }
    });

    var activeCategory = null;
    var activeSubcat = null;

    function parseSubcats(btn) {
      return (btn.dataset.subcategories || '').split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    }

    function showAll() {
      cards.forEach(function (c) { c.style.display = ''; });
    }

    function filterByCategory(subcatArray) {
      var set = new Set(subcatArray);
      cards.forEach(function (c) {
        var specs = (c.dataset.specialties || '').split(',').map(function (s) { return s.trim(); });
        c.style.display = specs.some(function (s) { return set.has(s); }) ? '' : 'none';
      });
    }

    function filterBySubcategory(spec) {
      cards.forEach(function (c) {
        var specs = (c.dataset.specialties || '').split(',').map(function (s) { return s.trim(); });
        c.style.display = specs.indexOf(spec) !== -1 ? '' : 'none';
      });
    }

    function buildSubcatPills(subcatArray) {
      pillsContainer.innerHTML = '';
      subcatArray.forEach(function (spec) {
        var hasArtist = cards.some(function (c) {
          var specs = (c.dataset.specialties || '').split(',').map(function (s) { return s.trim(); });
          return specs.indexOf(spec) !== -1;
        });
        if (!hasArtist) return;

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'artist-cards__filter-pill';
        btn.textContent = spec;
        btn.addEventListener('click', function () {
          if (activeSubcat === spec) {
            activeSubcat = null;
            pillsContainer.querySelectorAll('.artist-cards__filter-pill').forEach(function (p) {
              p.classList.remove('artist-cards__filter-pill--active');
            });
            var activeCatBtn = filterBar.querySelector('.artist-cards__filter-cat--active');
            filterByCategory(activeCatBtn ? parseSubcats(activeCatBtn) : []);
          } else {
            activeSubcat = spec;
            pillsContainer.querySelectorAll('.artist-cards__filter-pill').forEach(function (p) {
              p.classList.remove('artist-cards__filter-pill--active');
            });
            btn.classList.add('artist-cards__filter-pill--active');
            filterBySubcategory(spec);
          }
        });
        pillsContainer.appendChild(btn);
      });
    }

    catBtns.forEach(function (catBtn) {
      catBtn.addEventListener('click', function () {
        var cat = catBtn.dataset.category;
        var subcats = parseSubcats(catBtn);

        if (activeCategory === cat) {
          activeCategory = null;
          activeSubcat = null;
          catBtns.forEach(function (b) { b.classList.remove('artist-cards__filter-cat--active'); });
          pillsContainer.innerHTML = '';
          subcatRow.style.display = 'none';
          showAll();
        } else {
          activeCategory = cat;
          activeSubcat = null;
          catBtns.forEach(function (b) { b.classList.remove('artist-cards__filter-cat--active'); });
          catBtn.classList.add('artist-cards__filter-cat--active');
          buildSubcatPills(subcats);
          subcatRow.style.display = '';
          filterByCategory(subcats);
        }
      });
    });
  })();
</script>
{%- endif -%}

{% stylesheet %}
  .artist-cards {
    position: relative;
  }

  .artist-cards--bordered {
    border-top: 4px solid var(--artist-cards-accent);
    border-bottom: 4px solid var(--artist-cards-accent);
  }

  /* Inner page-width containers */
  .artist-cards__header,
  .artist-cards__grid-wrap {
    box-sizing: border-box;
    max-width: var(--page-content-width, 1280px);
    margin-inline: auto;
    padding-inline: 32px;
    width: 100%;
  }

  @media (min-width: 750px) {
    .artist-cards__header,
    .artist-cards__grid-wrap {
      padding-inline: 50px;
    }
  }

  /* Heading block */
  .artist-cards__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  @media (min-width: 750px) {
    .artist-cards__header {
      margin-bottom: 48px;
    }
  }

  /* Filter bar — full-width strip */
  .artist-cards__filter-bar {
    width: 100%;
    background: #b0aba0;
    border-top: 1px solid rgba(29, 22, 22, 0.12);
    border-bottom: 1px solid rgba(29, 22, 22, 0.12);
  }

  .artist-cards__filter-inner {
    padding-inline: 24px;
    padding-top: 16px;
    padding-bottom: 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-inner {
      padding-inline: 50px;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 24px;
    }
  }

  .artist-cards__filter-label {
    font-family: var(--font-h1--family);
    font-style: italic;
    font-size: 18px;
    color: #1d1616;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .artist-cards__filter-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    padding-block: 8px;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-pills {
      gap: 16px;
      padding-block: 0;
    }
  }

  .artist-cards__filter-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: #f8f5ed;
    border: 2px solid #1d1616;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #1d1616;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-pill {
      padding: 11px 20px;
    }
  }

  .artist-cards__filter-pill--active,
  .artist-cards__filter-pill:hover {
    background: #f1ebdb;
  }

  /* Category pills (row 1) */
  .artist-cards__filter-categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    width: 100%;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-categories {
      gap: 16px;
      width: auto;
    }
  }

  .artist-cards__filter-cat {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: #f8f5ed;
    border: 2px solid #1d1616;
    border-radius: 8px;
    font-family: var(--font-h1--family);
    font-size: 14px;
    font-weight: 400;
    font-style: italic;
    color: #1d1616;
    cursor: pointer;
    opacity: 0.8;
    transition: background 0.2s, color 0.2s, border-color 0.2s, opacity 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-cat {
      font-size: 18px;
      padding: 11px 20px;
    }
  }

  .artist-cards__filter-cat--active,
  .artist-cards__filter-cat:hover {
    background: #1d1616;
    color: #f8f5ed;
    opacity: 1;
  }

  .artist-cards__filter-inner--sub {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    padding-inline: 24px;
    padding-top: 0;
    padding-bottom: 16px;
    gap: 8px;
    position: static;
  }

  @media (min-width: 750px) {
    .artist-cards__filter-inner--sub {
      padding-inline: 50px;
      justify-content: center;
      gap: 16px;
      position: static;
    }
  }

  /* Grid */
  .artist-cards__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  @media (min-width: 750px) {
    .artist-cards__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 17px;
    }
  }

  .artist-cards__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-foreground-subdued);
  }

  /* Card */
  .artist-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--artist-cards-card-border, rgba(var(--color-foreground-rgb), 0.22));
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .artist-card[style*="display: none"],
  .artist-card[style*="display:none"] {
    display: none !important;
  }

  .artist-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .artist-card__image {
    aspect-ratio: 177 / 160;
    overflow: hidden;
    flex-shrink: 0;
  }

  @media (min-width: 750px) {
    .artist-card__image {
      aspect-ratio: 304 / 275;
    }
  }

  .artist-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .artist-card:hover .artist-card__image img {
    transform: scale(var(--hover-subtle-zoom-amount, 1.015));
  }

  .artist-card__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px 12px;
    flex: 1;
  }

  @media (min-width: 750px) {
    .artist-card__info {
      padding: 10px 13px 25px;
      gap: 8px;
    }
  }

  .artist-card__name {
    margin: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-foreground);
  }

  @media (min-width: 750px) {
    .artist-card__name {
      font-size: 24px;
    }
  }

  .artist-card__specialty {
    margin: 0;
    font-size: 12px;
    line-height: 1.3;
    color: var(--color-foreground-subdued);
  }

  @media (min-width: 750px) {
    .artist-card__specialty {
      font-size: 14px;
    }
  }

  .artist-card__link {
    display: inline-block;
    margin-top: auto;
    padding-top: 4px;
    font-size: 12px;
    font-weight: 700;
    color: var(--artist-cards-accent);
    border-bottom: 2px solid var(--artist-cards-accent);
    text-align: right;
    align-self: flex-end;
  }

  @media (min-width: 750px) {
    .artist-card__link {
      font-size: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Artist Cards",
  "tag": "section",
  "class": "artist-cards-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "@theme"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Link & accent color",
      "default": "#ce5454"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color"
    },
    {
      "type": "header",
      "content": "Section border"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show top & bottom border",
      "info": "Uses the link & accent color",
      "default": false
    },
    {
      "type": "header",
      "content": "Style filter bar"
    },
    {
      "type": "checkbox",
      "id": "show_filter_bar",
      "label": "Show style filter bar",
      "info": "Categories and styles are pulled from the Style Category metaobjects. Manage them in Content > Metaobjects.",
      "default": false
    },
    {
      "type": "text",
      "id": "filter_label",
      "label": "Filter label",
      "default": "Style"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Artist Cards",
      "settings": {
        "accent_color": "#ce5454"
      },
      "blocks": {
        "eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>The Team</p>",
            "type_preset": "custom",
            "font": "var(--font-body--family)",
            "enable_custom_font_weight": true,
            "weight": "700",
            "font_size": "0.75rem",
            "case": "uppercase",
            "letter_spacing": "loose",
            "text_color": "#ce5454",
            "alignment": "center"
          }
        },
        "heading": {
          "type": "text",
          "settings": {
            "text": "<p>A hive of creativity.</p>",
            "type_preset": "h1",
            "alignment": "center"
          }
        }
      },
      "block_order": ["eyebrow", "heading"]
    }
  ]
}
{% endschema %}
