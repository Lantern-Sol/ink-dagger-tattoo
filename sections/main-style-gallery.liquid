{%- comment -%}
  Renders a `style` metaobject as a general style gallery: hero banner +
  title/description/CTA, every artist's work tagged with this style in one
  shuffled grid with a zoom modal, and a "More Styles" carousel.
{%- endcomment -%}

{%- liquid
  assign style = metaobject
  assign initial_count = 16
  assign gallery_items = ''
  assign gallery_items = gallery_items | split: '@@'
  assign hero_image = blank
  assign styles_url = pages['styles'].url | default: '/pages/styles'

  assign has_color_override = false
  if section.settings.background_color != blank or section.settings.text_color != blank
    assign has_color_override = true
  endif
-%}

{%- if has_color_override -%}
  {%- render 'contrast-override',
    background_color: section.settings.background_color,
    text_color: section.settings.text_color,
    section_id: section.id -%}
{%- endif -%}

{%- paginate shop.metaobjects.project.values by 250 -%}
  {%- for project_entry in shop.metaobjects.project.values -%}
    {%- liquid
      if project_entry.style.value.system.id != style.system.id
        continue
      endif
      assign entry_artist = project_entry.artist.value
    -%}
    {%- for media in project_entry.images.value -%}
      {%- if media.media_type == 'video' -%}
        {%- continue -%}
      {%- endif -%}
      {%- if hero_image == blank -%}
        {%- assign hero_image = media -%}
      {%- endif -%}
      {%- capture item_html -%}
        <button
          type="button"
          class="style-gallery__thumb"
          on:click="/openModal"
          data-modal-src="{{ media | image_url: width: 900 }}"
          data-modal-srcset="{{ media | image_url: width: 400 }} 400w, {{ media | image_url: width: 700 }} 700w, {{ media | image_url: width: 1000 }} 1000w, {{ media | image_url: width: 1400 }} 1400w"
          data-modal-alt="{{ project_entry.name.value | escape }}"
          {%- if entry_artist != blank -%}
            data-artist-name="{{ entry_artist.name.value | escape }}"
            data-artist-specialties="{{ entry_artist.specialty.value | escape }}"
            data-artist-photo="{{ entry_artist.profile_image.value | image_url: width: 300 }}"
            data-artist-url="{{ entry_artist.system.url }}"
          {%- endif -%}
          aria-label="{{ 'style_gallery.view_image' | t }}"
        >
          {{ media | image_url: width: 700 | image_tag:
            loading: 'lazy',
            widths: '300, 450, 600, 700',
            sizes: '(min-width: 750px) 288px, 158px',
            class: 'style-gallery__thumb-image',
            alt: project_entry.name.value | escape }}
        </button>
      {%- endcapture -%}
      {%- assign item_array = item_html | split: '@@STYLE_GALLERY_ITEM@@' -%}
      {%- assign gallery_items = gallery_items | concat: item_array -%}
    {%- endfor -%}
  {%- endfor -%}
{%- endpaginate -%}

{%- assign gallery_items = gallery_items | shuffle -%}
{%- assign total_count = gallery_items.size -%}
{%- assign visible_items = gallery_items | slice: 0, initial_count -%}
{%- assign remaining_items = gallery_items | slice: initial_count, total_count -%}

{%- capture more_styles_html -%}
  {%- paginate shop.metaobjects.project.values by 250 -%}
    {%- for other_style in shop.metaobjects.style.values -%}
      {%- if other_style.system.id == style.system.id -%}
        {%- continue -%}
      {%- endif -%}
      {%- liquid
        assign other_style_image = blank
        for project_entry in shop.metaobjects.project.values
          if project_entry.style.value.system.id == other_style.system.id
            assign other_style_image = project_entry.images.value | first
            break
          endif
        endfor
      -%}
      {%- if other_style_image == blank -%}
        {%- continue -%}
      {%- endif -%}
      <li class="style-gallery__more-item">
        <a class="style-gallery__more-card" href="{{ other_style.system.url }}">
          {{ other_style_image | image_url: width: 700 | image_tag:
            loading: 'lazy',
            widths: '350, 500, 700',
            sizes: '(min-width: 750px) 33vw, 90vw',
            class: 'style-gallery__more-image',
            alt: other_style.name.value | escape }}
          <span class="style-gallery__more-info">
            <span class="style-gallery__more-name">{{ other_style.name.value | escape }}</span>
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow_ne' -%}
            </svg>
          </span>
        </a>
      </li>
    {%- endfor -%}
  {%- endpaginate -%}
{%- endcapture -%}

<style-gallery-component>
  <div
    class="style-gallery{% if has_color_override %} color-custom-{{ section.id }}{% endif %}"
    style="padding-block: {{ section.settings['padding-block-start'] | default: 64 }}px {{ section.settings['padding-block-end'] | default: 64 }}px;"
  >
    <div class="style-gallery__banner{% if hero_image == blank %} style-gallery__banner--no-image{% endif %}">
      {%- if hero_image != blank -%}
        {{ hero_image | image_url: width: 1600 | image_tag:
          loading: 'eager',
          widths: '750, 1100, 1440, 1600',
          sizes: '100vw',
          class: 'style-gallery__banner-image',
          alt: style.name.value | escape }}
        {%- if section.settings.toggle_overlay and section.settings.overlay_color != blank -%}
          <div class="style-gallery__banner-overlay" style="background-color: color-mix(in srgb, {{ section.settings.overlay_color }} {{ section.settings.overlay_opacity | default: 50 }}%, transparent);"></div>
        {%- endif -%}
      {%- endif -%}
      <p class="style-gallery__breadcrumb">
        <a class="style-gallery__breadcrumb-link" href="{{ routes.root_url }}">Home</a> / <a class="style-gallery__breadcrumb-link" href="{{ styles_url }}">Styles</a>{% if style.name.value != blank %} / {{ style.name.value | escape }}{% endif %}
      </p>
    </div>

    <div class="style-gallery__header">
      <div class="style-gallery__header-col">
        {%- if style.name.value != blank -%}
          <h1 class="style-gallery__title">{{ style.name.value | escape }}</h1>
        {%- endif -%}
        {%- if style.general_style_description.value != blank -%}
          <p class="style-gallery__description">{{ style.general_style_description.value }}</p>
        {%- endif -%}
      </div>
      <a
        class="style-gallery__cta button-custom"
        href="{{ section.settings.booking_url | default: '#' }}"
        style="--button-background-color: #ce5454; --button-color: #1d1616; --button-border-color: #1d1616; --button-border-width: 3px; border-radius: 8px;"
      >
        {{ section.settings.booking_label | default: 'Book Consultation' }}
        <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20">
          {%- render 'icon', icon: 'arrow_ne' -%}
        </svg>
      </a>
    </div>

    {%- if total_count == 0 -%}
      <p class="style-gallery__empty">{{ section.settings.empty_state_text | default: 'More work coming soon.' }}</p>
    {%- else -%}
      <ul class="style-gallery__grid" role="list">
        {%- for item in visible_items -%}
          {%- liquid
            assign grid_item = item
            if forloop.index0 < 4
              assign grid_item = item | replace: 'loading="lazy"', 'loading="eager"'
            endif
          -%}
          <li class="style-gallery__item">{{ grid_item }}</li>
        {%- endfor -%}
      </ul>

      {%- if total_count > initial_count -%}
        <template class="style-gallery__templates">
          {%- for item in remaining_items -%}
            <li class="style-gallery__item">{{ item }}</li>
          {%- endfor -%}
        </template>
        <div class="style-gallery__load-more">
          <button type="button" class="button-secondary" on:click="/loadMore">
            {{ section.settings.load_more_label | default: 'Load More Works' }}
          </button>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- if more_styles_html != blank -%}
    <div class="style-gallery__more">
      <h2 class="style-gallery__more-title">{{ section.settings.more_styles_heading | default: 'More Styles' }}</h2>
      <div class="style-gallery__more-layout">
        <ul class="style-gallery__more-track" role="list">
          {{ more_styles_html }}
        </ul>
        <div class="style-gallery__more-controls">
          <button type="button" class="style-gallery__more-nav style-gallery__more-nav--prev" on:click="/moreStylesPrev" aria-label="{{ 'style_gallery.previous_image' | t }}">
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow' -%}
            </svg>
          </button>
          <div class="style-gallery__more-dots" data-more-styles-dots></div>
          <button type="button" class="style-gallery__more-nav style-gallery__more-nav--next" on:click="/moreStylesNext" aria-label="{{ 'style_gallery.next_image' | t }}">
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
              {%- render 'icon', icon: 'arrow' -%}
            </svg>
          </button>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- render 'picture-modal' -%}
</style-gallery-component>

<script src="{{ 'style-gallery.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .style-gallery__banner {
    position: relative;
    width: 100%;
    aspect-ratio: 390 / 235;
    overflow: hidden;
    margin-bottom: 32px;
  }

  @media (min-width: 750px) {
    .style-gallery__banner {
      aspect-ratio: 1440 / 432;
      margin-bottom: 48px;
    }
  }

  .style-gallery__banner--no-image {
    aspect-ratio: auto;
    padding: 24px 32px;
  }

  @media (min-width: 750px) {
    .style-gallery__banner--no-image {
      padding: 24px 96px;
    }
  }

  .style-gallery__banner--no-image .style-gallery__breadcrumb {
    position: static;
  }

  .style-gallery__banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .style-gallery__banner-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .style-gallery__breadcrumb {
    position: absolute;
    z-index: 1;
    bottom: 32px;
    left: 32px;
    right: 32px;
    margin: 0;
    color: #ce5454;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .style-gallery__breadcrumb .style-gallery__breadcrumb-link {
    color: #ce5454;
    text-decoration: none;
  }

  .style-gallery__breadcrumb .style-gallery__breadcrumb-link:hover {
    color: #ce5454 !important;
    text-decoration: underline;
  }

  @media (min-width: 750px) {
    .style-gallery__breadcrumb {
      bottom: 32px;
      left: 96px;
      right: 96px;
      letter-spacing: 0.18em;
    }
  }

  .style-gallery__header {
    box-sizing: border-box;
    max-width: var(--page-content-width, 1280px);
    margin-inline: auto;
    padding-inline: 32px;
    padding-bottom: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  @media (min-width: 750px) {
    .style-gallery__header {
      padding-inline: 96px;
      padding-bottom: 48px;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .style-gallery__header-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1 1 0;
    min-width: 0;
  }

  .style-gallery__title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .style-gallery__title {
      font-size: 2.5rem;
    }
  }

  .style-gallery__description {
    margin: 0;
    max-width: 48rem;
    opacity: 0.85;
    line-height: 1.45;
  }

  .style-gallery__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 12px 24px;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    flex-shrink: 0;
  }

  @media (min-width: 750px) {
    .style-gallery__cta {
      width: auto;
      font-size: 1rem;
    }
  }

  .style-gallery__grid {
    box-sizing: border-box;
    max-width: var(--page-content-width, 1280px);
    margin-inline: auto;
    padding-inline: 32px;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    row-gap: 16px;
    column-gap: 8px;
    list-style: none;
    margin-block: 0;
  }

  @media (min-width: 750px) {
    .style-gallery__grid {
      padding-inline: 96px;
      grid-template-columns: repeat(4, 1fr);
      row-gap: 24px;
      column-gap: 32px;
    }
  }

  .style-gallery__thumb {
    display: block;
    width: 100%;
    aspect-ratio: 158 / 219;
    padding: 0;
    background: none;
    border: 1px solid #ce5454;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
  }

  @media (min-width: 750px) {
    .style-gallery__thumb {
      aspect-ratio: 288 / 400;
    }
  }

  .style-gallery__thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .style-gallery__load-more {
    display: flex;
    justify-content: center;
    padding-top: 16px;
  }

  .style-gallery__load-more[hidden] {
    display: none;
  }

  @media (min-width: 750px) {
    .style-gallery__load-more {
      padding-top: 24px;
    }
  }

  .style-gallery__empty {
    text-align: center;
    padding-block: 64px;
    color: var(--color-foreground-subdued, #6b6b6b);
  }

  .style-gallery__more {
    padding: 32px;
    background: #e3dfd6;
    border-top: 4px solid #cfc8b9;
  }

  @media (min-width: 750px) {
    .style-gallery__more {
      padding: 32px 96px 64px;
    }
  }

  .style-gallery__more-title {
    margin: 0 0 24px;
    font-family: 'Libre Baskerville', var(--font-heading--family), serif;
    font-weight: 400;
    font-size: 24px;
    letter-spacing: -0.02em;
    color: #ce5454;
  }

  @media (min-width: 750px) {
    .style-gallery__more-title {
      font-size: 32px;
      margin-bottom: 32px;
    }
  }

  .style-gallery__more-layout {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .style-gallery__more-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    max-width: 100%;
  }

  @media (min-width: 750px) {
    .style-gallery__more-layout {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-areas: 'prev track next' '. dots .';
      align-items: center;
      gap: 16px;
    }

    .style-gallery__more-track {
      grid-area: track;
    }

    .style-gallery__more-controls {
      display: contents;
    }

    .style-gallery__more-nav--prev {
      grid-area: prev;
    }

    .style-gallery__more-nav--next {
      grid-area: next;
    }

    .style-gallery__more-dots {
      grid-area: dots;
      justify-self: center;
    }
  }

  .style-gallery__more-nav {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    color: #1d1616;
    border: 2px solid #1d1616;
    border-radius: 8px;
    cursor: pointer;
  }

  .style-gallery__more-nav svg {
    width: 14px;
    height: 14px;
  }

  .style-gallery__more-nav--prev svg {
    transform: rotate(180deg);
  }

  .style-gallery__more-track {
    display: flex;
    width: 100%;
    min-width: 0;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .style-gallery__more-track::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 750px) {
    .style-gallery__more-track {
      gap: 32px;
    }
  }

  .style-gallery__more-item {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  @media (min-width: 750px) {
    .style-gallery__more-item {
      flex: 0 0 calc((100% - 64px) / 3);
    }
  }

  .style-gallery__more-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 16px;
    border: 1px solid rgba(29, 22, 22, 0.22);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: #1d1616;
  }

  @media (min-width: 750px) {
    .style-gallery__more-card {
      gap: 24px;
      padding-bottom: 24px;
    }
  }

  .style-gallery__more-image {
    width: 100%;
    aspect-ratio: 329 / 351;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 750px) {
    .style-gallery__more-image {
      aspect-ratio: 346 / 392;
    }
  }

  .style-gallery__more-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 16px;
  }

  @media (min-width: 750px) {
    .style-gallery__more-info {
      padding-inline: 24px;
    }
  }

  .style-gallery__more-name {
    font-family: 'Libre Baskerville', var(--font-heading--family), serif;
    font-size: 24px;
  }

  .style-gallery__more-info svg {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    color: #ce5454;
  }

  .style-gallery__more-dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .style-gallery__more-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: #4c4546;
    cursor: pointer;
  }

  .style-gallery__more-dot--active {
    background: #ce5454;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Style Gallery",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Hero banner"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Enable overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#1d1616"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Booking"
    },
    {
      "type": "url",
      "id": "booking_url",
      "label": "Booking link"
    },
    {
      "type": "text",
      "id": "booking_label",
      "label": "Booking button label",
      "default": "Book Consultation"
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load more button label",
      "default": "Load More Works"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty state text",
      "default": "More work coming soon."
    },
    {
      "type": "header",
      "content": "More Styles"
    },
    {
      "type": "text",
      "id": "more_styles_heading",
      "label": "Heading",
      "default": "More Styles"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ]
}
{% endschema %}
