{%- comment -%}
  Renders a "Stories Featuring [Artist]" band: blog posts whose
  "Artists related to post" metafield (article.metafields.custom.artists_related_to_post,
  a list.metaobject_reference to the `artist` metaobject) includes the current
  artist. Standalone section — resolves its own artist from `metaobject` so it
  can be dropped onto any metaobject template (project pages today, the main
  artist page potentially later) without further changes.
{%- endcomment -%}

{%- liquid
  assign artist = blank
  if metaobject.system.type == 'artist'
    assign artist = metaobject
  else
    assign artist = metaobject.artist.value
  endif

  assign max_posts = 4
  assign matches = 0

  assign all_articles = blogs['events'].articles | concat: blogs['guest-artists'].articles | concat: blogs['learn'].articles | concat: blogs['job-listings'].articles
  assign all_articles = all_articles | sort: 'published_at' | reverse
-%}

{% capture cards %}
  {%- for article in all_articles -%}
    {%- if matches >= max_posts -%}
      {%- break -%}
    {%- endif -%}
    {%- liquid
      assign is_match = false
      for related_artist in article.metafields.custom.artists_related_to_post.value
        if related_artist.system.id == artist.system.id
          assign is_match = true
          break
        endif
      endfor
    -%}
    {%- if is_match -%}
      {%- assign matches = matches | plus: 1 -%}
      {%- liquid
        assign excerpt = article.excerpt | default: article.content | strip_html | truncatewords: 25
      -%}
      <a href="{{ article.url }}" class="artist-journal__card">
        <div class="artist-journal__image">
          {%- if article.image != blank -%}
            {{
              article.image
              | image_url: width: 700
              | image_tag:
                loading: 'lazy',
                widths: '350, 500, 700',
                sizes: '(min-width: 750px) 25vw, 45vw',
                alt: article.title | escape
            }}
          {%- endif -%}
        </div>
        <div class="artist-journal__info">
          <span class="artist-journal__title">{{ article.title | escape }}</span>
          {%- if excerpt != blank -%}
            <span class="artist-journal__excerpt-row">
              <span class="artist-journal__excerpt">{{ excerpt }}</span>
              <svg class="artist-journal__arrow" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 20 20">
                {%- render 'icon', icon: 'arrow_ne' -%}
              </svg>
            </span>
          {%- endif -%}
        </div>
      </a>
    {%- endif -%}
  {%- endfor -%}
{% endcapture %}

{% capture prev_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
    <path d="M11.1226 7.13234L2.87722 6.86839M6.28094 3.67583L2.87722 6.86839L6.06978 10.2721" stroke="#1D1616" stroke-width="1.45833"/>
  </svg>
{% endcapture %}
{% capture next_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
    <path d="M2.87743 7.13234L11.1228 6.86839M7.71906 3.67583L11.1228 6.86839L7.93022 10.2721" stroke="#1D1616" stroke-width="1.45833"/>
  </svg>
{% endcapture %}

{% if matches > 0 %}
  <div
    class="artist-journal"
    style="
      --aj-bg: {{ section.settings.background_color }};
      --aj-text: {{ section.settings.text_color }};
      --aj-accent: {{ section.settings.accent_color }};
      --aj-border: {{ section.settings.border_color }};
    "
  >
    <div class="artist-journal__inner">
      <div class="artist-journal__header">
        {%- if section.settings.journal_eyebrow != blank -%}
          <p class="artist-journal__eyebrow">{{ section.settings.journal_eyebrow }}</p>
        {%- endif -%}
        <h2 class="artist-journal__heading">
          {{ section.settings.journal_heading_prefix }} {{ artist.name.value | escape }}
        </h2>
        {%- if section.settings.journal_view_all_label != blank -%}
          <a class="artist-journal__view-all" href="{{ section.settings.journal_view_all_url | default: '#' }}">
            {{ section.settings.journal_view_all_label }} <span aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>

      <artist-journal-carousel>
        <div class="artist-journal__track" data-track>
          {{ cards }}
        </div>

        {%- if matches > 1 -%}
          <div class="artist-journal__controls">
            <button type="button" class="artist-journal__arrow-btn" aria-label="Previous" data-prev>
              {{ prev_icon }}
            </button>
            <div class="artist-journal__dots" data-dots></div>
            <button type="button" class="artist-journal__arrow-btn" aria-label="Next" data-next>
              {{ next_icon }}
            </button>
          </div>
        {%- endif -%}
      </artist-journal-carousel>
    </div>
  </div>

  <script src="{{ 'artist-journal-carousel.js' | asset_url }}" defer></script>
{% endif %}

{% style %}
  .artist-journal {
    border-top: 4px solid var(--aj-border);
    background-color: var(--aj-bg);
    padding-block: 2rem;
  }

  @media (min-width: 750px) {
    .artist-journal {
      padding-block: 2rem 4rem;
    }
  }

  .artist-journal__inner {
    box-sizing: border-box;
    max-width: 90rem;
    margin-inline: auto;
    padding-inline: 32px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 750px) {
    .artist-journal__inner { padding-inline: 96px; }
  }

  .artist-journal__header {
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: 1rem;
    row-gap: 0.625rem;
    align-items: center;
  }

  .artist-journal__eyebrow { grid-column: 1; grid-row: 1; }
  .artist-journal__view-all { grid-column: 2; grid-row: 1; align-self: center; }
  .artist-journal__heading { grid-column: 1 / -1; grid-row: 2; }

  @media (min-width: 750px) {
    .artist-journal__header {
      row-gap: 0.625rem;
    }

    .artist-journal__eyebrow { grid-column: 1; grid-row: 1; }
    .artist-journal__heading { grid-column: 1; grid-row: 2; }
    .artist-journal__view-all { grid-column: 2; grid-row: 1 / span 2; align-self: end; }
  }

  .artist-journal__eyebrow {
    margin: 0;
    color: var(--aj-accent);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .artist-journal__heading {
    margin: 0;
    font-family: var(--font-heading--family, serif);
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: -0.021em;
    color: var(--aj-text);
  }

  @media (min-width: 750px) {
    .artist-journal__heading { font-size: 2rem; letter-spacing: -0.016em; }
  }

  .artist-journal__view-all {
    color: var(--aj-accent);
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .artist-journal__view-all:hover { text-decoration: underline; }

  artist-journal-carousel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .artist-journal__track {
    display: flex;
    align-items: stretch;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: auto;
    scrollbar-width: none;
  }

  .artist-journal__track::-webkit-scrollbar { display: none; }

  .artist-journal__card {
    flex: 0 0 calc((100% - 8px) / 2);
    scroll-snap-align: start;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-bottom: 1.125rem;
    border: 1px solid var(--aj-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--aj-text);
  }

  @media (min-width: 750px) {
    .artist-journal__card {
      flex: 0 0 calc((100% - (3 * 1.5rem)) / 4);
    }

    .artist-journal__track { gap: 1.5rem; }
  }

  .artist-journal__image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 6px 6px 0 0;
  }

  .artist-journal__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .artist-journal__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-inline: 1rem;
  }

  .artist-journal__title {
    font-family: var(--font-heading--family, serif);
    font-size: 0.875rem;
    line-height: 1.2;
  }

  @media (min-width: 750px) {
    .artist-journal__title { font-size: 1rem; }
  }

  .artist-journal__excerpt-row {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
  }

  .artist-journal__excerpt {
    flex: 1 1 auto;
    min-width: 0;
    color: color-mix(in srgb, var(--aj-text) 70%, transparent);
    font-size: 0.75rem;
    line-height: 1.15rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  @media (min-width: 750px) {
    .artist-journal__excerpt { font-size: 0.875rem; }
  }

  .artist-journal__arrow {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--aj-accent);
  }

  .artist-journal__controls,
  .artist-journal__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .artist-journal__arrow-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: transparent;
    color: var(--aj-text);
    border: 2px solid var(--aj-text);
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .artist-journal__arrow-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .artist-journal__dots .artist-journal__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background-color: var(--aj-border);
    cursor: pointer;
  }

  .artist-journal__dots .artist-journal__dot[aria-selected='true'] {
    background-color: var(--aj-accent);
  }

  /* Desktop is a static row capped at 4 cards — never scrolls, so the
     mobile-only controls are hidden outright (not just disabled). */
  @media (min-width: 750px) {
    .artist-journal__controls { display: none; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Artist Journal",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Scans every blog in the store for posts whose \"Artists related to post\" field includes this page's artist."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f5ed"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1d1616"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ce5454",
      "info": "Used for the eyebrow, \"View all posts\" link, card arrow icons, and active carousel dot."
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#cfc8b9",
      "info": "Used for the top divider, card borders, and the mobile carousel dots. Carousel arrow buttons use the text color instead, for contrast."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "journal_eyebrow",
      "label": "Eyebrow text",
      "default": "On the journal"
    },
    {
      "type": "text",
      "id": "journal_heading_prefix",
      "label": "Heading prefix",
      "default": "Stories Featuring",
      "info": "The artist's name is appended automatically, e.g. \"Stories Featuring David Staniforth\"."
    },
    {
      "type": "text",
      "id": "journal_view_all_label",
      "label": "\"View all posts\" link label",
      "default": "View all posts"
    },
    {
      "type": "url",
      "id": "journal_view_all_url",
      "label": "\"View all posts\" link"
    }
  ],
  "presets": [
    {
      "name": "Artist Journal"
    }
  ]
}
{% endschema %}
